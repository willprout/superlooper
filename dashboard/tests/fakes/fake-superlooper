#!/usr/bin/env python3
"""A stand-in for the `superlooper` CLI, driven by a fixture directory ŌĆö the test harness the
dashboard's local-command adapter (``lib/tidy.py``) runs against so no test ever reaches the REAL
``superlooper`` binary (which closes cmux windows ŌĆö a stray real call would touch William's live
sessions). The conftest guard already points ``SL_SUPERLOOPER`` at an absent path by default; a
tidy test overrides it in-body to THIS executable.

Point the adapter at it with ``SL_SUPERLOOPER=<path>/fake-superlooper`` and a fixtures dir env ŌĆö
``SL_TIDY_FIXTURES`` (Tidy) or ``SL_JANITOR_FIXTURES`` (Janitor, issue #121). This models the
subcommand shapes the two local-command buttons drive:

    superlooper tidy --repo <path> --dry-run              ŌåÆ LISTS windows tidy would close
    superlooper tidy --repo <path> --yes                  ŌåÆ CLOSES them (skips the y/N)
    superlooper janitor --repo <path> --json              ŌåÆ PROPOSES GitHub debris as JSON
    superlooper janitor --repo <path> --json --execute-keys k1,k2  ŌåÆ executes that tapped subset

The janitor path prints ``$FIX/propose.json`` / ``$FIX/execute.json`` when present (a test can
inject a fail-closed ``{"ok": false, ...}`` envelope), else a default 3-proposal snapshot / an
ok-per-key result echoing the requested keys, and records a ``janitor_execute`` mutation carrying
the exact keys so a test proves ONLY the tapped subset was sent.

It also models the Restart button's shell (issue #116; see ``route_request_restart``):

    superlooper request-restart --repo <path> --check --json   ŌåÆ reports live-runner liveness (JSON)
    superlooper request-restart --repo <path> --json           ŌåÆ 'drops the marker' (records a call)

- ``--dry-run`` prints the contents of ``$SL_TIDY_FIXTURES/dry_run.txt`` when present, else a
  default two-window listing in the REAL CLI's exact print format (``  {id:5} {status:13}
  {surface}``), so ``lib/tidy.parse_windows`` is exercised against the true shape.
- ``--yes`` prints ``$SL_TIDY_FIXTURES/execute.txt`` when present, else a default ``closed N
  window(s).`` line, and records a ``close`` mutation so a test can assert the execute path ran.

Every invocation's full argv (and cwd) is logged to ``$SL_TIDY_FIXTURES/calls.jsonl`` BEFORE any
sleep/fail, so a test can pin the exact contract the adapter produced ŌĆö that ``--repo`` was the
right checkout, that ``--dry-run`` vs ``--yes`` was chosen correctly, and CRUCIALLY that ``--all``
was NEVER passed (issue #41: merged-only scope; the dashboard never exposes ``--all``).

Fail injection (exercises the adapter's fail-closed paths):
- ``SL_TIDY_SLEEP=<secs>``  makes the call sleep, so a short adapter timeout trips (rc 124 path).
- ``SL_TIDY_FAIL=1``        makes the call exit nonzero with a stderr message (the missing-binary /
                            command-error path ŌĆö must surface plainly, never a silent success).

Mirrors ``tests/fakes/fake-gh``.
"""
import json
import os
import sys
import time

ARGS = sys.argv[1:]
# One fixtures dir, whichever local-command button set it (Tidy or Janitor). calls.jsonl and
# mutations.jsonl land here for either verb.
FIX = (os.environ.get("SL_TIDY_FIXTURES") or os.environ.get("SL_JANITOR_FIXTURES")
       or os.environ.get("SL_FIXER_FIXTURES") or "")

_DEFAULT_DRY_RUN = (
    "tidy will close 2 finished (merged) session window(s):\n"
    "  i23   merged        cmux:surface-23\n"
    "  i16   merged        (no surface)\n"
    "dry-run: nothing closed.\n"
)
_DEFAULT_EXECUTE = "tidy will close 2 finished (merged) session window(s):\n" \
                   "  i23   merged        cmux:surface-23\n" \
                   "  i16   merged        (no surface)\n" \
                   "closed 2 window(s).\n"

# The default `janitor --json` snapshot: one proposal per debris class, in the CLI's exact
# envelope shape ({"ok", "proposals":[{kind,key,action,target,why(,head|title)}], "held",
# "aged_park_days"}), so lib/janitor.parse_propose / group_proposals run against the true format.
_DEFAULT_PROPOSE = {
    "ok": True,
    "proposals": [
        {"kind": "branch", "key": "branch:sl/i23-old-thing", "action": "delete-branch",
         "target": "sl/i23-old-thing", "why": "PR #40 merged ŌĆö the work is on the mainline"},
        {"kind": "pr", "key": "pr:41", "action": "close-pr", "target": 41, "head": "sl/i18-x",
         "why": "open but superseded ŌĆö replaced by a rebuild; the branch stays"},
        {"kind": "issue", "key": "issue:9", "action": "close-issue", "target": 9,
         "title": "flaky retry logic",
         "why": "parked and untouched for 30d (threshold 14d)"},
    ],
    "held": [],
    "aged_park_days": 14,
}


def die(msg, code=1):
    sys.stderr.write("fake-superlooper: %s\n" % msg)
    sys.exit(code)


def fixture(name, default):
    """The contents of ``$SL_TIDY_FIXTURES/<name>`` if present, else ``default``."""
    path = os.path.join(FIX, name)
    if FIX and os.path.isfile(path):
        with open(path) as f:
            return f.read()
    return default


def record(kind, **extra):
    rec = {"kind": kind}
    rec.update(extra)
    with open(os.path.join(FIX, "mutations.jsonl"), "a") as f:
        f.write(json.dumps(rec) + "\n")


def opt(flag):
    if flag in ARGS:
        i = ARGS.index(flag)
        if i + 1 < len(ARGS):
            return ARGS[i + 1]
    return None


def _janitor():
    """`superlooper janitor --json [--execute-keys k1,k2]`. --execute-keys ŌåÆ the subset executor
    (records a mutation carrying the exact keys, echoes one ok result per key); otherwise the
    machine-readable propose. Exit code tracks the real CLI: nonzero when the envelope is a
    fail-closed refusal (``ok: false``) or when an executed action failed (``failed > 0``)."""
    keys_arg = opt("--execute-keys")
    if keys_arg is not None:
        keys = [k for k in keys_arg.split(",") if k]
        record("janitor_execute", repo=opt("--repo"), keys=keys)
        default = {"ok": True,
                   "results": [{"key": k, "outcome": "ok"} for k in keys],
                   "executed": len(keys), "failed": 0, "skipped": 0, "held": 0}
        out = fixture("execute.json", json.dumps(default))
    else:
        out = fixture("propose.json", json.dumps(_DEFAULT_PROPOSE))
    sys.stdout.write(out)
    try:
        doc = json.loads(out)
    except ValueError:
        doc = {}
    sys.exit(0 if (doc.get("ok") and not doc.get("failed")) else 1)


def route():
    if ARGS[:1] == ["janitor"]:
        _janitor()
        return
    if ARGS[:1] == ["request-restart"]:
        route_request_restart()
        return
    if ARGS[:1] == ["debug"]:
        route_debug()
        return
    if ARGS[:1] != ["tidy"]:
        die("unhandled command: %s" % " ".join(ARGS))
    if "--dry-run" in ARGS:
        sys.stdout.write(fixture("dry_run.txt", _DEFAULT_DRY_RUN))
        sys.exit(0)
    # --yes (or a bare tidy) ŌåÆ the execute path. Record it so a test can assert the close ran.
    record("tidy_execute", repo=opt("--repo"), yes=("--yes" in ARGS), all=("--all" in ARGS))
    sys.stdout.write(fixture("execute.txt", _DEFAULT_EXECUTE))
    sys.exit(0)


def route_request_restart():
    """Model the real `superlooper request-restart --json` contract the dashboard's ``lib/restart``
    parses (issue #116). ``SL_RESTART_RUNNING=0`` simulates no live runner (the dead-runner refuse);
    ``SL_RESTART_GARBAGE=1`` prints non-JSON so a test can exercise the adapter's unparseable path.
    ``--check`` reports liveness and writes nothing; the plain form 'writes the marker' (recorded as
    a mutation so a test can assert the request landed, with its audit fields)."""
    if os.environ.get("SL_RESTART_GARBAGE"):
        sys.stdout.write("not json ŌĆö the CLI misbehaved\n")
        sys.exit(0)
    running = os.environ.get("SL_RESTART_RUNNING", "1") != "0"
    repo = opt("--repo") or ""
    manual = "open a cmux tab and run: superlooper run --repo %s" % repo
    pid = 4242 if running else None
    if "--check" in ARGS:
        out = {"ok": True, "verb": "request-restart", "running": running, "pid": pid,
               "requested": False, "manual": manual}
        sys.stdout.write(json.dumps(out) + "\n")
        sys.exit(0)
    if not running:
        out = {"ok": False, "verb": "request-restart", "running": False, "pid": None,
               "requested": False, "manual": manual,
               "error": "no runner is live for this repo ŌĆö nothing to restart"}
        sys.stdout.write(json.dumps(out) + "\n")
        sys.exit(1)
    record("restart_request", repo=repo, operator=opt("--operator"), source=opt("--source"))
    out = {"ok": True, "verb": "request-restart", "running": True, "pid": pid,
           "requested": True, "manual": manual}
    sys.stdout.write(json.dumps(out) + "\n")
    sys.exit(0)


def route_debug():
    """Model the real `superlooper debug --json` contract ``lib/fixer`` parses (issue #144) ŌĆö the
    ENGINE's owner-tap debugger launch, which owns the id allocation, the single-flight lock, the
    brief and the launch handshake. The dashboard only shells it, so this fake is the whole of what
    a fixer test may see of a launch.

    ``SL_DEBUG_LIVE=d3`` simulates a debugger already on this patient (the engine's refusal);
    ``SL_DEBUG_FAIL=1`` simulates a launch that did not land; ``SL_DEBUG_GARBAGE=1`` prints non-JSON
    so a test can exercise the adapter's unparseable path. ``--check`` reports liveness and writes
    nothing; the plain form records a mutation carrying the note, the audit fields and the CONTEXT
    the dashboard piped in, so a test can prove the owner's words reached the engine verbatim."""
    if os.environ.get("SL_DEBUG_GARBAGE"):
        sys.stdout.write("not json ŌĆö the CLI misbehaved\n")
        sys.exit(0)
    live = os.environ.get("SL_DEBUG_LIVE") or ""
    if "--check" in ARGS:
        out = {"ok": True, "verb": "debug-check", "id": None,
               "live": bool(live), "live_id": live or None}
        sys.stdout.write(json.dumps(out) + "\n")
        sys.exit(0)
    # Drain stdin exactly as the real verb does for `--context-file -`, so a test can assert what
    # the dashboard piped over (and so a large context can never deadlock the adapter).
    context = sys.stdin.read() if opt("--context-file") == "-" else ""
    if live:
        out = {"ok": False, "verb": "debug", "id": None, "live": True, "live_id": live,
               "error": "a debugger session (%s) is already running for this repo ŌĆö never two "
                        "debuggers on one patient" % live}
        sys.stdout.write(json.dumps(out) + "\n")
        sys.exit(1)
    record("debug_launch", repo=opt("--repo"), note=opt("--note"), context=context,
           operator=opt("--operator"), source=opt("--source"))
    if os.environ.get("SL_DEBUG_FAIL"):
        out = {"ok": False, "verb": "debug", "id": "d4", "live": False, "live_id": None,
               "error": "the launch timed out ŌĆö no session was confirmed"}
        sys.stdout.write(json.dumps(out) + "\n")
        sys.exit(1)
    out = {"ok": True, "verb": "debug", "id": "d4", "live": True, "live_id": "d4",
           "brief": "/nonexistent/home/briefs/d4.md"}
    sys.stdout.write(json.dumps(out) + "\n")
    sys.exit(0)


def main():
    if FIX:
        with open(os.path.join(FIX, "calls.jsonl"), "a") as f:
            f.write(json.dumps({"argv": ARGS, "cwd": os.getcwd()}) + "\n")
    if os.environ.get("SL_TIDY_SLEEP") or os.environ.get("SL_JANITOR_SLEEP"):
        time.sleep(float(os.environ.get("SL_TIDY_SLEEP") or os.environ.get("SL_JANITOR_SLEEP")))
    if os.environ.get("SL_TIDY_FAIL") or os.environ.get("SL_JANITOR_FAIL"):
        die("forced failure")
    route()


if __name__ == "__main__":
    main()
