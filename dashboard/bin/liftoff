#!/usr/bin/env python3
"""liftoff — the ONE command that brings up the pair (issue #45).

Today the operator starts the runner and the dashboard separately. ``liftoff`` starts — or verifies
already-running — BOTH: this dashboard and one watched repo's runner. Run it BY HAND inside a cmux
tab, exactly like ``superlooper run``: it starts the dashboard in the BACKGROUND (a localhost server
needs no tab) and then FOREGROUNDS the runner in the current tab, so the runner lands in a visible
cmux tab — the one proven restart procedure (the engine's runner-ops.md). No automated tab placement;
your real tab is the anchor.

Two boundaries (see lib/liftoff.py):
  * the engine stays dashboard-agnostic — liftoff shells the engine's OWN ``superlooper run`` through
    the config's ``superlooper_cli`` (the same generic pointer the Tidy button uses), never a
    hardcoded engine path;
  * idempotent — it probes the dashboard's port and the runner's pidfile first, and never
    double-starts either; each side's own guard (the dashboard's bind-failed exit, issue #34; the
    runner's pidfile singleton) is the backstop, so even a racing probe is safe.

``--restart-dashboard`` (issue #136) is the one exception to "verify, leave alone": it stops the
running dashboard and starts it again on the CURRENT build. A server keeps the Python it loaded at
boot while serving static files from disk every request, so a merge to the dashboard's own face lands
new buttons in a running dashboard's browser that its router never learned — and the idempotent path
above can never heal that, because leaving an up dashboard alone is precisely its contract. The
remedy lives here, in a command read fresh from disk, rather than in a dashboard button: a stale
server is stale BECAUSE it lacks the newly merged routes, so a restart endpoint would 404 on exactly
the servers that need it. Dashboard-only — it never touches the runner and never claims the tab.

Run:  bin/liftoff [config.json] [--repo <slug|name|path>]   (default config: ./config.json, or $CC_CONFIG)
      With one watched repo, --repo is optional. With several, name which runner to start.
      bin/liftoff --restart-dashboard   (restart a STALE TOWER on the current build, then exit)
"""
import errno
import json
import os
import signal
import socket
import subprocess
import sys
import time
import urllib.request
from pathlib import Path

# Exit codes. Distinct so a supervisor / a human reading a log can tell a first-run config dead-end
# from a launch failure — the same discipline bin/command-center uses (issue #34).
EXIT_CONFIG_ERROR = 2   # config missing / malformed / schema-invalid, or an unresolvable --repo
EXIT_LAUNCH_FAILED = 3  # the runner could not be exec'd (bad CLI path) / the dashboard couldn't spawn

_ROOT = Path(__file__).resolve().parent.parent
# lib before anything else so `import config` / `liftoff` / `server` resolve without an install step
# (mirrors bin/command-center + tests/conftest.py, so entry point and tests agree on resolution).
sys.path.insert(0, str(_ROOT / "lib"))

import config as config_mod   # noqa: E402
import liftoff as liftoff_mod  # noqa: E402
import server                 # noqa: E402

_COMMAND_CENTER = str(_ROOT / "bin" / "command-center")
_USAGE = ("usage: liftoff [config.json] [--repo <slug|name|path>] [--restart-dashboard]\n"
          "  Brings up (or verifies) the dashboard + one watched repo's runner. Run inside a cmux "
          "tab.\n"
          "  --restart-dashboard  Stop the running dashboard and start it again on the current\n"
          "                       build, then exit. Use when the dashboard reports a stale tower:\n"
          "                       a running server keeps the Python it loaded at boot, so a merge\n"
          "                       lands new buttons in the browser that its router never learned.\n"
          "                       Dashboard only — never touches the runner, never claims the tab.\n")

# How long to wait for a stopped dashboard to actually stop answering, before refusing to start a
# replacement beside it. A localhost server with no in-flight work goes in well under a second; the
# ceiling only has to outlast a slow shutdown, and overshooting it costs nothing but a moment of the
# owner's patience — whereas giving up too early would be a double start, the one outcome barred.
_STOP_TIMEOUT = 10.0
_STOP_POLL = 0.2


class _Usage(Exception):
    """A usage message to print then exit. ``code`` is 0 for an explicit ``--help`` (help is not an
    error) and EXIT_CONFIG_ERROR for a genuine parse error."""

    def __init__(self, message, code=EXIT_CONFIG_ERROR):
        super().__init__(message)
        self.code = code


def _parse_args(argv):
    """``(config_path, repo_arg, restart_dashboard)`` from ``argv``. Manual parse (like
    bin/command-center) so a bad flag fails through our own friendly path, never argparse's bare
    SystemExit."""
    config_path, repo_arg, restart_dashboard = None, None, False
    rest = argv[1:]
    i = 0
    while i < len(rest):
        a = rest[i]
        if a in ("-h", "--help"):
            raise _Usage(_USAGE, code=0)
        if a in ("--repo", "-r"):
            if i + 1 >= len(rest):
                raise _Usage("liftoff: --repo needs a value\n" + _USAGE)
            repo_arg = rest[i + 1]
            i += 2
            continue
        if a == "--restart-dashboard":
            restart_dashboard = True
        elif a.startswith("--repo="):
            repo_arg = a.split("=", 1)[1]
        elif a.startswith("-"):
            raise _Usage("liftoff: unknown option %r\n%s" % (a, _USAGE))
        elif config_path is None:
            config_path = a
        else:
            raise _Usage("liftoff: unexpected extra argument %r\n%s" % (a, _USAGE))
        i += 1
    if config_path is None:
        config_path = os.environ.get("CC_CONFIG", "config.json")
    return config_path, repo_arg, restart_dashboard


def _state_base():
    """The writable base under which loop state (and our dashboard log) lives — the same derivation
    as ``config.state_home`` so liftoff and the runner agree on where ``~/.superlooper`` is."""
    return os.environ.get("SL_HOME") or os.path.expanduser("~/.superlooper")


def _dashboard_snapshot(host, port):
    """The live command-center's ``/api/snapshot`` as a dict, or ``None`` if what answers on
    ``host:port`` is not ours. Verified by SHAPE, not merely by something holding the port — so an
    UNRELATED app squatting it reads as "not ours". A short timeout keeps the probe cheap; any error
    (refused, timeout, non-200, non-JSON, wrong shape) ⇒ None.

    This shape check is what makes ``--restart-dashboard`` safe to give a kill target: the pid it
    reads comes from the very process that answered as OUR dashboard, so liftoff can never signal a
    stranger. (issue #136)"""
    url = "http://%s:%d/api/snapshot" % (host, port)
    try:
        with urllib.request.urlopen(url, timeout=1.0) as resp:   # HTTPError (>=400) raises → caught
            body = json.loads(resp.read())
    except (OSError, ValueError):
        return None
    if isinstance(body, dict) and "generated_at" in body and "repos" in body:
        return body
    return None


def _dashboard_up(host, port):
    """True ONLY if command-center ITSELF is already serving on ``host:port`` — see
    :func:`_dashboard_snapshot` for the shape check. A false "already serving" would leave the
    operator with no dashboard, so a squatter reads as not-up: liftoff then tries to start ours and
    the dashboard's own bind-failed guard (issue #34) reports the port conflict honestly."""
    return _dashboard_snapshot(host, port) is not None


def _port_busy(host, port):
    """Is ANYTHING accepting TCP on ``host:port``? A raw connect — no HTTP, no shape check, no
    opinion about what is listening (issue #136).

    This is the question that actually governs a restart, and the two richer probes each answer it
    wrongly in one direction:

    * ``_dashboard_snapshot`` says "no" for a timeout or a truncated body — i.e. for a dashboard that
      is WEDGED BUT ALIVE and still holding the port. Start a replacement on that "no" and it dies at
      bind while the stale server keeps answering.
    * ``os.kill(pid, 0)`` says "yes" for a process that has exited but not been reaped. A zombie holds
      no socket; refusing to start over one strands the owner with no dashboard at all.

    The kernel's listen socket has neither confusion: a wedged server still accepts, a zombie does
    not. The port is the contended resource, so the port is what we ask about. On loopback a connect
    either completes or is refused at once, so this stays instant."""
    try:
        with socket.create_connection((host, port), timeout=1.0):
            return True
    except OSError:      # refused / unreachable / timed out ⇒ nothing is holding it
        return False


def _stop_process(pid):
    """Ask the dashboard to stop: SIGTERM to EXACTLY the pid it reported for itself (never a name or
    pattern — ``pkill -f bin/command-center`` also matches William's own live dashboard, and did kill
    it, 2026-07-07). An already-dead pid is success, not an error. Any OTHER OSError (EPERM: the pid
    is not ours) propagates to the caller, which reports it and starts nothing — a dashboard we could
    not stop must never get a second one started beside it."""
    try:
        os.kill(pid, signal.SIGTERM)
    except ProcessLookupError:
        pass          # already gone — that is the outcome we wanted


def _pid_alive(pid):
    """Whether ``pid`` is a live process — signal 0 probes without touching it. EPERM means it
    exists but we don't own it (still alive). Mirrors the runner's own liveness check."""
    try:
        os.kill(pid, 0)
    except OSError as e:
        return e.errno == errno.EPERM
    return True


def _live_runner_pid(state_home):
    """The LIVE runner pid for a repo, or ``None``: the pidfile's recorded pid, but only if that
    process is actually alive (a stale lock from a crashed runner reads as no live runner)."""
    pid = liftoff_mod.runner_lock_pid(state_home)
    return pid if (pid is not None and _pid_alive(pid)) else None


def _spawn_dashboard(argv, log_path):
    """Start the dashboard server detached in the BACKGROUND: its own session (survives liftoff being
    replaced by the runner exec), stdin off, stdout/stderr to a log the operator can tail. The
    dashboard's bind-failed guard (issue #34) means a racing double-spawn exits cleanly, not a
    crash-loop."""
    os.makedirs(os.path.dirname(log_path), exist_ok=True)
    log = open(log_path, "a")
    devnull = open(os.devnull, "r")
    subprocess.Popen(argv, stdin=devnull, stdout=log, stderr=subprocess.STDOUT,
                     start_new_session=True, close_fds=True)


def _exec_runner(argv):
    """Replace THIS process with ``superlooper run`` — so the current cmux tab becomes the runner's
    tab (the proven procedure; the engine's own preflight then confirms it can see this tab). Uses
    ``execvp`` (not ``execv``) so a bare or relative ``superlooper_cli`` — which the config contract
    explicitly allows, "resolved against PATH like gh's bare gh" — is found on PATH; an absolute path
    (the default) is used as-is. Never returns on success."""
    os.execvp(argv[0], argv)


def _restart_dashboard(cfg, config_path, url, out, *, dashboard_snapshot, stop_process,
                       spawn_dashboard, sleep, port_busy):
    """``--restart-dashboard`` (issue #136): stop the running dashboard and start it again on the
    current build. Dashboard only — the runner is never touched and this tab is never claimed.

    The never-double-start guarantee rests on ONE question, asked of the kernel: **is the port still
    taken?** Nothing is spawned until it is free. Two dashboards cannot share a port — one dies at
    bind, and the owner cannot tell which one is answering them — so "free" is the whole precondition,
    and every softer proxy for it gets this wrong somewhere (see :func:`_port_busy`).

    A silent port is not the same as an empty one, either: the snapshot probe answers ``None`` for a
    wedged-but-alive server that never let go of the socket, so "nothing is serving" has to mean the
    kernel refused the connection, not merely that nobody said hello.
    """
    port = cfg["port"]
    decision = liftoff_mod.dashboard_restart_decision(
        url, dashboard_snapshot(server.BIND_HOST, port),
        port_busy=port_busy(server.BIND_HOST, port))
    out.write("liftoff: %s\n" % decision["message"])
    if decision["action"] == "refuse":
        return EXIT_LAUNCH_FAILED

    if decision["action"] == "stop-then-start":
        pid = decision["pid"]
        try:
            stop_process(pid)
        except OSError as e:
            # EPERM (not our process) lands here. We could not stop it ⇒ we do not replace it.
            out.write("liftoff: could not stop the dashboard (pid %d): %s — starting nothing.\n"
                      % (pid, e))
            return EXIT_LAUNCH_FAILED
        deadline = time.monotonic() + _STOP_TIMEOUT
        while port_busy(server.BIND_HOST, port):
            if time.monotonic() >= deadline:
                out.write(
                    "liftoff: port %d is still held %ds after the dashboard (pid %d) was asked to "
                    "stop — starting nothing.\n"
                    "  Two dashboards cannot share a port. Stop it by hand (kill -9 %d), then run: "
                    "liftoff --restart-dashboard\n" % (port, int(_STOP_TIMEOUT), pid, pid))
                return EXIT_LAUNCH_FAILED
            sleep(_STOP_POLL)
        out.write("liftoff: the old dashboard (pid %d) has stopped and released port %d\n"
                  % (pid, port))

    log_path = os.path.join(_state_base(), "command-center.log")
    try:
        spawn_dashboard(liftoff_mod.dashboard_argv(sys.executable, _COMMAND_CENTER, config_path),
                        log_path)
    except OSError as e:
        out.write("liftoff: could not start the dashboard (%s)\n" % e)
        return EXIT_LAUNCH_FAILED
    out.write("liftoff: started the dashboard on the current build → %s (logging to %s)\n"
              % (url, log_path))
    return 0


def main(argv, *, is_dashboard_up=_dashboard_up, live_runner_pid=_live_runner_pid,
         spawn_dashboard=_spawn_dashboard, exec_runner=_exec_runner, out=None,
         dashboard_snapshot=_dashboard_snapshot, stop_process=_stop_process, sleep=time.sleep,
         port_busy=_port_busy):
    out = out if out is not None else sys.stderr
    try:
        config_path, repo_arg, restart_dashboard = _parse_args(argv)
    except _Usage as e:
        out.write(str(e))
        return e.code

    # A missing config is the first-run dead-end (issue #104): answer it BEFORE config.load with a
    # message that names WHERE liftoff looked (the absolute path — a relative ./config.json resolves
    # against the cwd, not the script) and every way out. config.load's own FileNotFoundError below
    # stays as the TOCTOU backstop (file deleted between this check and the read).
    if not os.path.exists(config_path):
        looked_at = os.path.abspath(config_path)
        sibling = str(_ROOT / "config.json")
        # A config that ships next to the script (its own ../config.json) — named, never auto-used —
        # unless it IS the path we just looked at (then there is genuinely no config anywhere).
        script_dir_config = (os.path.abspath(sibling)
                             if os.path.exists(sibling)
                             and os.path.realpath(sibling) != os.path.realpath(config_path)
                             else None)
        example = str(_ROOT / "config.example.json")
        example_config = os.path.abspath(example) if os.path.exists(example) else None
        out.write(liftoff_mod.missing_config_message(
            looked_at, script_dir_config=script_dir_config, example_config=example_config))
        return EXIT_CONFIG_ERROR

    try:
        cfg = config_mod.load(config_path)
    except (FileNotFoundError, ValueError) as e:
        out.write("liftoff: %s\n" % e)
        return EXIT_CONFIG_ERROR

    # --restart-dashboard is a focused, dashboard-only verb and returns here: it never resolves a
    # repo (it steers no runner, so --repo would be a question with no purpose), never execs, and
    # never claims this tab. That is what makes it safe to run from whatever terminal the owner
    # happens to be reading the stale-tower notice in.
    if restart_dashboard:
        return _restart_dashboard(cfg, config_path,
                                  "http://%s:%d" % (server.BIND_HOST, cfg["port"]), out,
                                  dashboard_snapshot=dashboard_snapshot, stop_process=stop_process,
                                  spawn_dashboard=spawn_dashboard, sleep=sleep, port_busy=port_busy)

    try:
        repo = liftoff_mod.resolve_repo(cfg, repo_arg)
    except ValueError as e:
        out.write("liftoff: %s\n" % e)
        return EXIT_CONFIG_ERROR

    url = "http://%s:%d" % (server.BIND_HOST, cfg["port"])
    dash_argv = liftoff_mod.dashboard_argv(sys.executable, _COMMAND_CENTER, config_path)
    run_argv = liftoff_mod.runner_argv(cfg["superlooper_cli"], repo["path"])
    plan = liftoff_mod.make_plan(
        repo, url, dash_argv, run_argv,
        dashboard_up=is_dashboard_up(server.BIND_HOST, cfg["port"]),
        runner_pid=live_runner_pid(repo["state_home"]))

    # 1) Dashboard first — it must be up (and stay up) before liftoff hands the tab to the runner.
    dash = plan["dashboard"]
    if dash["start"]:
        log_path = os.path.join(_state_base(), "command-center.log")
        try:
            spawn_dashboard(dash["argv"], log_path)
        except OSError as e:
            out.write("liftoff: could not start the dashboard (%s)\n" % e)
            return EXIT_LAUNCH_FAILED
        out.write("liftoff: %s (logging to %s)\n" % (dash["message"], log_path))
    else:
        out.write("liftoff: %s\n" % dash["message"])

    # 2) Runner — foreground in THIS cmux tab (the proven procedure), unless one is already live.
    run = plan["runner"]
    out.write("liftoff: %s\n" % run["message"])
    if not run["start"]:
        return 0
    out.flush()
    try:
        exec_runner(run["argv"])   # replaces this process on success — nothing below runs
    except OSError as e:
        out.write("liftoff: could not start the runner via %r (%s)\n"
                  "  Check 'superlooper_cli' in your config.json, and run liftoff inside a cmux tab.\n"
                  % (run["argv"][0], e))
        return EXIT_LAUNCH_FAILED
    return 0   # only reached under an injected exec_runner (tests); a real execv never returns


if __name__ == "__main__":
    sys.exit(main(sys.argv))
