_TEMPLATES = os.path.abspath(os.path.join(_HERE, "..", "templates"))

# cmux close settings, kept in step with runner.py (the agent boundary: cmux specifics stay in
# the launch/close machinery — this CLI's `tidy` copies the runner's proven _close_stale_session
# close, it does not invent a second one).
_CMUX_DEFAULT = "/Applications/cmux.app/Contents/Resources/bin/cmux"   # SL_CMUX overrides (tests)
_CLOSE_TIMEOUT = 15            # bound the best-effort close of a finished session's pane

# The §C.2 label set, colors included so a fresh repo reads well at a glance. adopt creates
# all of them idempotently (--force). Runner-managed labels say so — humans learn the loop's
# vocabulary from the label descriptions. `{operator}` in a description is substituted with the
# configured operator name at adopt time (issue #58), so a stranger's own labels sign their name.
LABELS = [
    ("agent-ready", "0e8a16", "{operator}'s approval: the runner may launch this issue"),
    ("in-progress", "fbca04", "claimed by a loop session (runner-managed)"),
    ("needs-owner", "d93f0b", "parked for an owner decision (runner-managed)"),
    ("parked", "c2e0c6", "handed back to {operator} with a memo (runner-managed)"),
    ("expedite", "b60205", "queue-bypass lane: the next free lane takes this first"),
    ("preserve", "5319e7", "on a PR: resolve conflicts in-branch instead of regenerating"),
    ("auto-approved:nightly-red", "e99695",
     "standing rule: auto-filed fix for a red nightly/dev (scoped to restoring green)"),
    ("superseded", "cccccc", "on a PR: replaced by a rebuild; branch preserved, nothing auto-closed"),
    ("priority:high", "ff9500", "front of the normal queue"),
    ("priority:low", "0075ca", "back of the queue"),
    ("type:build", "1d76db", "build issue"),
    ("type:investigate", "6f42c1", "investigation issue (report + children, no PR)"),
    ("type:diagnose-and-fix", "0052cc", "diagnose-and-fix issue (scope check first)"),
    # Per-issue control knobs (owner ruling 2026-07-07): William drops one on an issue to run its
    # worker sessions on a specific model/effort. gh refuses to apply a label that doesn't exist, so
    # these are a STARTER set — the runner has no allowlist, so any `model:<x>`/`effort:<x>` label
    # you create and apply works (an unknown value fails the launch loudly and parks the issue).
    ("model:opus", "0366d6", "per-issue worker model: latest Opus (~200K context)"),
    ("model:opus[1m]", "0366d6", "per-issue worker model: latest Opus + 1M context"),
    ("model:fable", "0366d6", "per-issue worker model: Fable"),
    ("effort:low", "8256d0", "per-issue worker effort: low"),
    ("effort:medium", "8256d0", "per-issue worker effort: medium"),
    ("effort:high", "8256d0", "per-issue worker effort: high"),
    ("effort:xhigh", "8256d0", "per-issue worker effort: xhigh"),
    ("effort:max", "8256d0", "per-issue worker effort: max"),
]


# Runner-managed label preflight (issue #108). RATIONALE — FAIL LOUD, never auto-create:
# `in-progress` / `needs-owner` / `parked` are the labels the RUNNER itself ADDS as machinery when
# it hands an issue back to the owner (park/bounce) or claims one (launch). `gh` refuses to apply a
# label that does not exist, so if one is missing every hand-back label move FAILS and — before
# issue #108's bounce/park guards — retried FOREVER (the 2026-07-13 storm: #58 renamed
# needs-william->needs-owner inside adopt, nobody re-ran adopt after the republish, and the bounce
# executor re-fired the owner text every ~18s until the label was hand-created). `doctor` checks the
# whole label set, but nothing forces a doctor run after a republish, so the runner must defend
# itself at boot. It FAILS LOUD (returns nonzero, naming the label + the exact `superlooper adopt`
# remediation) rather than auto-creating the labels: `adopt` is the sole label-mutation authority
# (see CLAUDE.md ▸ the adopt/doctor split and "facts enter through the config contract") — a boot
# that silently created labels would fork that authority and mask a broken adoption — and refusing
# to start in a broken state mirrors the established boot-preflight discipline (preflight_pane, the
# FAILS-HARD-when-empty required_checks check, issue #104's missing-config start-up error). The
# runner-managed SUBSET is derived from the "(runner-managed)" tag in each LABELS description, so
# LABELS stays the single source of truth. (`agent-ready` is the owner's word, not runner-managed,
# and `superseded` is best-effort — regenerate proceeds even if its add fails — so neither storms.)


def runner_managed_labels():
    """The runner-managed subset of LABELS — the labels the RUNNER writes as machinery, tagged
    '(runner-managed)' in their descriptions (in-progress, needs-owner, parked)."""
    return [name for name, _color, desc in LABELS if "(runner-managed)" in desc]


def missing_runner_labels(existing):
    """The runner-managed labels ABSENT from `existing` (a set/list of label names), in LABELS
    order. Fails closed on a wrong-typed `existing` (treats it as empty -> every one missing), so a
    garbage gh read never masquerades as 'all present'."""
    have = set(existing) if isinstance(existing, (set, list, tuple, frozenset)) else set()
    return [n for n in runner_managed_labels() if n not in have]

_CHECKS_REQUIREMENT = (
    "REQUIREMENT: `required_checks` must name at least one CI check that runs this repo's\n"
    "tests. A repo with no required check has NO mechanical ship gate (§4.3) — the loop would\n"
    "merge on vibes. Add the check to .superlooper/config.json AND to the branch protection.")

# Issue #26: a `required_checks` entry naming a check the repo never reports (a name typo, or a
# check reporting on PRs but never on the dev branch) reads as "pending" forever — it keeps a green
# PR gating with no merge, no park, no memo. The doctor cross-checks every name against what recent
# PRs and the dev branch have ACTUALLY reported and fails at adoption time, before 3am.
_CHECKS_NAMES_REQUIREMENT = (
    "REQUIREMENT: every `required_checks` name must EXACTLY match a check the repo actually\n"
    "reports (GitHub matches required checks by exact name — 'quality-gate' != 'Quality Gate').\n"
    "A name it never reports reads as pending forever: a green PR gates with no merge, no park.\n"
    "Fix the name in .superlooper/config.json, or wire the check to report (for the dev-branch\n"
    "case, ensure its workflow triggers on push to the dev branch, not only on pull_request).")

_STANDING_RULES_START = "<!-- loop-standing-rules:start -->"
_STANDING_RULES_END = "<!-- loop-standing-rules:end -->"
_STANDING_RULES_BLOCK = f"""\
{_STANDING_RULES_START}
## Loop Standing Rules

- Approval is the repo owner's word. `agent-ready` is never applied by an agent without that approval.
- Read the parked-issue memo before re-approving a parked issue; the memo is part of the current request.
- Reviews are performed by a fresh agent that wrote none of the code. Review prompts must name the known defect classes: shared mutable defaults; fail-open on wrong-typed input.
- No metered or paid spend without explicit owner confirmation in the current conversation.
- Never work in the loop's own checkout; work only in the target repo checkout for the approved issue.
{_STANDING_RULES_END}"""
_STANDING_RULES_START_BYTES = _STANDING_RULES_START.encode("utf-8")
_STANDING_RULES_END_BYTES = _STANDING_RULES_END.encode("utf-8")
_STANDING_RULES_BLOCK_BYTES = _STANDING_RULES_BLOCK.encode("utf-8")


def _read(path):
    try:
        with open(path) as f:
            return f.read()
    except OSError:
        return None


def _load_config(repo_path):
    """config load + the D1 repo pin: every gh call this process makes must target config.repo,
    never whatever repo the operator's cwd happens to sit in (live dry-run 2026-07-03: a runner
    started outside the adopted repo silently talked to the wrong repo — or none). Every command
    that loads a config loads it through here."""
    cfg = config_lib.load(repo_path)
    gh.set_repo(cfg.get("repo"))
    return cfg


def _origin_repo(repo_path):
    """owner/name from the git origin remote, or None (adopt falls back to the placeholder)."""
    try:
        r = subprocess.run(["git", "-C", repo_path, "remote", "get-url", "origin"],
                           capture_output=True, text=True, timeout=10)
    except (OSError, subprocess.TimeoutExpired):
        return None
    if r.returncode != 0:
        return None
    m = re.search(r"github\.com[:/]([^/\s]+/[^/\s]+?)(?:\.git)?/?$", r.stdout.strip())
    return m.group(1) if m else None


def _seed_standing_rules(repo_path):
    """Create or update the target repo's CLAUDE.md standing-rules block."""
    path = os.path.join(repo_path, "CLAUDE.md")
    try:
        with open(path, "rb") as f:
            existing = f.read()
    except OSError:
        with open(path, "wb") as f:
            f.write(_STANDING_RULES_BLOCK_BYTES)
            f.write(b"\n")
        return "created"

    start = existing.find(_STANDING_RULES_START_BYTES)
    end = existing.find(_STANDING_RULES_END_BYTES, start + len(_STANDING_RULES_START_BYTES))
    if start >= 0 and end >= 0:
        end += len(_STANDING_RULES_END_BYTES)
        updated = existing[:start] + _STANDING_RULES_BLOCK_BYTES + existing[end:]
        if updated != existing:
            with open(path, "wb") as f:
                f.write(updated)
        return "updated"

    if existing == b"":
        sep = b""
    elif existing.endswith(b"\r\n\r\n") or existing.endswith(b"\n\n"):
        sep = b""
    elif existing.endswith(b"\r\n"):
        sep = b"\r\n"
    elif existing.endswith(b"\n"):
        sep = b"\n"
    else:
        sep = b"\r\n\r\n" if b"\r\n" in existing else b"\n\n"
    with open(path, "wb") as f:
        f.write(existing)
        f.write(sep)
        f.write(_STANDING_RULES_BLOCK_BYTES)
        f.write(b"\n")
    return "appended"


# ------------------------------- run -------------------------------

def cmd_run(args):
    from runner import Runner, preflight_pane, detect_self_anchor
    cfg = _load_config(args.repo)
    fetch_usage = None
    fake = os.environ.get("SL_FAKE_USAGE")
    if fake:
        # test/simulation seam (Task 15's offline harness): never touch the Keychain/endpoint
        fetch_usage = lambda: json.loads(fake)
    # Anchor resolution (owner request 2026-07-06 — never hardcode a pane): one cmux `identify`
    # names the tab THIS `superlooper run` is executing in — its pane (the `new-surface` target) and
    # the workspace/window it lives in. An explicit --pane / $SL_PANE still wins for the pane; the
    # workspace/window come from identify regardless (they describe where the runner actually IS).
    # Empty only when started outside cmux with no override — preflight then fails hard.
    anchor = detect_self_anchor()
    pane = args.pane or os.environ.get("SL_PANE") or anchor["pane"]
    src = ("--pane" if args.pane else "$SL_PANE" if os.environ.get("SL_PANE")
           else "this cmux tab" if pane else "(none)")
    agent = args.agent or cfg.get("agent", "claude")
    r = Runner(repo=args.repo, config=cfg, pane=pane, agent=agent,
               workspace=anchor["workspace"], window=anchor["window"], fetch_usage=fetch_usage)
    # Anchor identity in the boot line (issue #33): the pane is WHAT worker tabs are born in;
    # workspace/window name WHERE — so a runner started in the wrong cmux window (the 2026-07-09
    # focused-window misplacement) is visible at a glance, not an opaque pane UUID that fits any
    # window. Show whichever of workspace/window cmux resolved; omit the rest (no empty noise).
    loc = "".join(f" {k}={v}" for k, v in (("workspace", r.workspace), ("window", r.window)) if v)
    print(f"superlooper run: repo={args.repo} state={r.home} pane={r.pane or '(unset)'} "
          f"[{src}]{loc} agent={r.agent}")
    # D7: fail HARD before the loop if cmux is unreachable or the pane won't resolve. A quiet
    # warning here once let a mis-started runner silently abort every launch and burn every
    # issue's retry cap (live dry-run 2026-07-03/04) — so this refuses to start instead.
    ok, why = preflight_pane(r.pane)
    if not ok:
        print(f"FATAL: {why}", file=sys.stderr)
        print("Start `superlooper run` INSIDE a visible cmux tab — it targets that tab's own pane "
              "automatically (no --pane needed). Only pass --pane / $SL_PANE to override.",
              file=sys.stderr)
        return 2
    # Runner-managed label preflight (issue #108 — rationale in the LABELS section above): the
    # runner MOVES needs-owner/parked/in-progress as machinery; if one is missing it cannot hand
    # issues back, so refuse to start and NAME the fix. But a transient blip at boot must NEVER block
    # a restart, so this fails loud ONLY on a POSITIVE proof of absence — a CLEAN, well-typed label
    # read (`labels_health().ok`) that genuinely lacks a runner-managed label. A refused read fails
    # closed to an empty set (ok=False) and SKIPS the check, exactly like an unreachable gh. This is
    # the #92 refused-vs-answered-empty discipline: `gh api rate_limit` (probe) is EXEMPT from rate
    # limiting, so it reads OK while the core label read is throttled — reading that throttled-empty
    # as "every label missing" would wedge the boot during the very rate-limit window it must survive.
    labels = gh.labels_health()
    if labels.ok:
        missing = missing_runner_labels(labels.value)
        if missing:
            print(f"FATAL: runner-managed label(s) missing from {cfg.get('repo')}: "
                  f"{', '.join(missing)}", file=sys.stderr)
            print("These are how the runner hands issues back (park/bounce) and claims them "
                  "(launch); gh refuses to apply a label that doesn't exist, so every hand-back "
                  "would fail and retry. Create them (adopt is idempotent — it updates existing "
                  f"labels in place, never duplicates):\n  superlooper adopt --repo {args.repo}",
                  file=sys.stderr)
            return 2
    return r.run(max_ticks=args.ticks)


# ------------------------------- request-restart (issue #116) -------------------------------

def _emit_restart(args, result):
    """Print a request-restart result: one JSON object when ``--json`` (for a local ops UI over the
    loop to parse), else a plain human line for a terminal operator."""
    if getattr(args, "json", False):
        sys.stdout.write(json.dumps(result) + "\n")
        return
    if result.get("requested"):
        sys.stdout.write("restart requested — the live runner (pid %s) will restart itself in its "
                         "own cmux tab after the current tick.\n" % result.get("pid"))
    elif result.get("running"):
        sys.stdout.write("a runner is live for this repo (pid %s).\n" % result.get("pid"))
    else:
        sys.stdout.write("no runner is live for this repo — nothing to restart.\n  %s\n"
                         % result.get("manual"))


def cmd_request_restart(args):
    """Ask the LIVE runner to restart ITSELF in its own cmux tab (issue #116). A local ops UI over
    the loop shells this (exactly as it shells ``superlooper tidy``); it can also be run by hand.

    It NEVER launches or places a tab: it only drops a request marker in the state home that a
    RUNNING runner honors between ticks by re-exec'ing in place (a fresh process image that reloads
    the installed engine and clears in-memory episode state). With no live runner it makes no attempt
    to resurrect one — resurrecting a dead loop is out, because a runner must run in a visible cmux
    tab a human opened and automated tab placement is owner-ruled out (2026-07-09). It refuses and
    names the one-line manual start instead.

    ``--check`` reports whether a live runner exists and writes NOTHING (the button's preflight);
    ``--json`` emits one JSON object for the dashboard; ``--operator``/``--source`` are audit fields
    recorded in the marker (the runner journals them when it honors the restart)."""
    from runner import live_runner_pid, write_restart_request
    cfg = _load_config(args.repo)
    state_dir = os.path.join(str(config_lib.state_home(cfg)), "state")
    manual = "open a cmux tab and run: superlooper run --repo %s" % os.path.abspath(args.repo)
    pid = live_runner_pid(state_dir)                      # None ⇒ stale/absent pidfile ⇒ no live runner
    running = pid is not None

    if getattr(args, "check", False):                    # preflight only — never writes the marker
        _emit_restart(args, {"ok": True, "verb": "request-restart", "running": running,
                             "pid": pid, "requested": False, "manual": manual})
        return 0

    if not running:                                      # dead-runner case — launch/place NOTHING
        _emit_restart(args, {"ok": False, "verb": "request-restart", "running": False, "pid": None,
                             "requested": False, "manual": manual,
                             "error": "no runner is live for this repo — nothing to restart"})
        return 1

    # Bind the marker to the pid we just saw live, so a runner that dies before honoring it can't
    # have a freshly-started replacement (a new pid) spuriously honor it (fresh-agent review).
    write_restart_request(state_dir, {"requested_at": int(time.time()), "target_pid": pid,
                                      "source": args.source or "cli", "operator": args.operator})
    _emit_restart(args, {"ok": True, "verb": "request-restart", "running": True, "pid": pid,
                         "requested": True, "manual": manual})
    return 0


# ------------------------------- status -------------------------------

def cmd_status(args):
    cfg = _load_config(args.repo)
    home = str(config_lib.state_home(cfg))
    hb = _read(os.path.join(home, "state", "runner.heartbeat"))
    has_state = os.path.exists(os.path.join(home, "state", "issues.json"))
    if hb is None and not has_state:
        print(f"no runner has ever run for this repo (state home: {home})")
        return 0
    if hb is None:
        print(f"runner: no heartbeat yet   state home: {home}")
    else:
        age = int(time.time() - int(hb.strip() or 0))
        print(f"runner: last heartbeat {age}s ago   state home: {home}")
    alert = _read(os.path.join(home, "state", "ALERT"))
    print(f"ALERT: {alert.strip()}" if alert else "ALERT: none")
    frozen = _read(os.path.join(home, "state", "merges_frozen.json"))
    if frozen:
        try:
            reason = json.loads(frozen).get("reason")
        except ValueError:
            reason = "(unreadable marker)"
        print(f"merges: FROZEN — {reason}")
    else:
        print("merges: flowing")

    try:
        st = loopstate.load(os.path.join(home, "state", "issues.json"))
    except (OSError, ValueError):
        st = {"issues": {}}
    issues = st.get("issues") if isinstance(st.get("issues"), dict) else {}
    inflight = {"running", "blocked", "frozen", "exited"}
    lanes = [(i, d) for i, d in sorted(issues.items()) if isinstance(d, dict)
             and d.get("status") in inflight]
    gate = [(i, d) for i, d in sorted(issues.items()) if isinstance(d, dict)
            and d.get("status") in ("gating", "holding")]
    print(f"\nlanes ({len(lanes)} occupied):")
    for iid, d in lanes or []:
        print(f"  {iid}  {d.get('status'):8}  {d.get('branch') or '-'}  "
              f"retries={d.get('retries', 0)} conflicts={d.get('conflicts', 0)}")
    if not lanes:
        print("  (empty)")
    print(f"gate ({len(gate)}):")
    for iid, d in gate or []:
        print(f"  {iid}  {d.get('status'):8}  {d.get('branch') or '-'}")
    if not gate:
        print("  (empty)")
    terminal = {}
    for i, d in issues.items():
        if isinstance(d, dict) and d.get("status") in ("merged", "parked", "needs_william",
                                                       "bounced"):
            terminal[d["status"]] = terminal.get(d["status"], 0) + 1
    print("terminal: " + (", ".join(f"{v} {k}" for k, v in sorted(terminal.items()))
                          or "(none)"))
    tail = journal.read(home)[-8:]
    print("\nrecent journal:")
    for rec in tail:
        who = rec.get("id") or rec.get("date") or ""
        print(f"  {int(rec.get('ts', 0))}  {rec.get('act'):16} {who:6} "
              f"{rec.get('outcome', '')}")
    if not tail:
        print("  (empty)")
    return 0


# ------------------------------- adopt -------------------------------

def cmd_adopt(args):
    cfg_path = os.path.join(args.repo, ".superlooper", "config.json")
    if os.path.exists(cfg_path):
        print(f"already adopted: {cfg_path} exists — config left untouched.")
    else:
        template = _read(os.path.join(_TEMPLATES, "config.example.json")) or "{}"
        cfg = json.loads(template)
        detected = _origin_repo(args.repo)
        if detected:
            cfg["repo"] = detected
            # issue #28: detect the repo's REAL default branch and write it as dev_branch. Left at
            # the template's "main", a master/develop repo fails every launch at worktree creation
            # (the base ref origin/main does not exist). Pin gh to the detected slug first so the
            # query targets THIS repo, not whatever the cwd resolves. gh unreachable -> None -> keep
            # the template default (doctor is the backstop that FAILs on a wrong guess).
            gh.set_repo(detected)
            default = gh.default_branch()
            if default:
                cfg["dev_branch"] = default
        os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
        with open(cfg_path, "w") as f:
            json.dump(cfg, f, indent=2)
            f.write("\n")
        print(f"wrote {cfg_path}" + ("" if detected else
              ' — EDIT the "repo" field (no github.com origin remote to detect it from)'))

    claude_action = _seed_standing_rules(args.repo)
    print(f"{claude_action} {os.path.join(args.repo, 'CLAUDE.md')} standing-rules block")

    # D1 pin, adopt's own way: the config may be freshly written (not yet loadable through the
    # full validator) — pin gh to whatever repo slug the config carries (detected origin on a
    # fresh adopt, the operator's value on re-adopt). An undetected placeholder ("owner/name")
    # still pins: label creation then fails LOUDLY against the placeholder instead of silently
    # creating labels in whatever repo the cwd happens to be.
    raw_cfg = _read(cfg_path)
    try:
        parsed_cfg = (json.loads(raw_cfg) or {}) if raw_cfg else {}
    except ValueError:
        parsed_cfg = {}
    parsed_cfg = parsed_cfg if isinstance(parsed_cfg, dict) else {}
    slug = parsed_cfg.get("repo")
    gh.set_repo(slug)

    # operator display name (issue #58): the name every stranger-visible label description signs
    # with — an explicit `operator` in the config wins, else the repo owner's GitHub login.
    op = config_lib.operator(parsed_cfg)

    # Migration (issue #58): a repo adopted before this change carries a `needs-william` label.
    # Rename it in place to the neutral `needs-owner` — preserving it on every issue that carries it
    # — so a stranger's own audit trail stops reading another person's name. Idempotent: skipped when
    # the repo already has `needs-owner`, or never had `needs-william`. Runtime reads recognize BOTH
    # (lib/janitor.py, lib/watchdog.py, dashboard), so a repo mid-migration keeps working either way.
    have = gh.labels()
    if "needs-william" in have and "needs-owner" not in have:
        migrated = gh.rename_label("needs-william", "needs-owner")
        print(f"migrating label: {'ok  ' if migrated else 'FAIL'} needs-william -> needs-owner")

    print("creating the label set (idempotent):")
    failed = []
    for name, color, desc in LABELS:
        ok = gh.create_label(name, color, desc.replace("{operator}", op))
        print(f"  {'ok  ' if ok else 'FAIL'} {name}")
        if not ok:
            failed.append(name)

    dev = "main"
    raw = _read(cfg_path)
    if raw:
        try:
            dev = json.loads(raw).get("dev_branch") or "main"
        except ValueError:
            pass
    print(f"""
Branch protection recommendations for `{dev}` (print-only in v1 — apply by hand):
  - require a pull request before merging (the loop only ever merges PRs)
  - require status checks to pass: your `required_checks` list
  - do NOT require branches to be up to date before merging — the loop's merge policy is
    completion-order with a mechanical merge-update ladder (§4.4); a strict up-to-date rule
    just recreates the old merge train
  - keep force pushes blocked (superlooper has no force path at all)

{_CHECKS_REQUIREMENT}""")

    # Issue #29: adopt's GitHub half can fail while its file half succeeds — run before `gh auth
    # login`, every label create fails but the config is already on disk. Exiting 0 there reports
    # a success that never happened: the config names labels the runner cannot apply, and the gap
    # only surfaces later as a mysteriously idle loop (an approved issue that never gets launched).
    # So: any label create/verify failure is a HARD nonzero exit, closing with the mixed state
    # named plainly (config kept, labels pending) and the one action most likely to fix it. adopt
    # stays idempotent, so the memo can honestly promise a clean re-run.
    if failed:
        print(f"""
LABEL SETUP INCOMPLETE — {len(failed)} of {len(LABELS)} label(s) could not be created:
  {', '.join(failed)}
The config IS written and kept ({cfg_path}); the labels are PENDING. Until they exist nobody
can apply them — gh refuses to apply a label that does not exist — so an issue can't even be
marked `agent-ready` to approve it, and the loop looks mysteriously idle rather than erroring.
Most likely cause: gh is not authenticated. Run `gh auth login`, then re-run this exact
command — `superlooper adopt --repo {args.repo}` is idempotent and safe to re-run (existing
labels are updated in place, never duplicated).""")
        return 1
    return 0


# ------------------------------- doctor -------------------------------

def cmd_stack_doctor(args):
    cfg = None
    cfg_error = None
    try:
        cfg = _load_config(args.repo)
    except (FileNotFoundError, ValueError) as e:
        cfg_error = e

    print("superlooper doctor --stack")
    # repo_path feeds the installed-engine drift row: in the dogfood loop args.repo (default: cwd) is
    # itself a superlooper source checkout, which is where publish drift can be measured (issue #39).
    results = stack_doctor.check_stack(cfg, config_error=cfg_error, repo_path=args.repo)
    for line in stack_doctor.format_results(results):
        print(line)
    failures = [r.name for r in results if not r.ok]
    if failures:
        print(f"\nSTACK DOCTOR FAILED: {', '.join(failures)}")
        return 1
    warnings = [r.name for r in results if getattr(r, "warn", False)]
    if warnings:
        # A WARN never fails the stack (exit 0), but naming it in the pass line keeps "all stack
        # checks passed" honest — e.g. a Claude-only machine with no Codex installed (issue #30).
        print(f"\nall stack checks passed (warnings: {', '.join(warnings)})")
        return 0
    print("\nall stack checks passed")
    return 0


def cmd_doctor(args):
    if getattr(args, "stack", False):
        return cmd_stack_doctor(args)

    failures = []

    def check(name, ok, detail=""):
        print(f"  {'ok  ' if ok else 'FAIL'} {name}" + (f" — {detail}" if detail else ""))
        if not ok:
            failures.append(name)

    print(f"superlooper doctor: {args.repo}")
    cfg = None
    try:
        cfg = _load_config(args.repo)
        check("config", True, "valid")
    except (FileNotFoundError, ValueError) as e:
        check("config", False, str(e))

    pr_req, dev_req, rc_union = [], [], []
    if cfg is not None:
        # required_checks may be split by surface (issue #52): the PR set gates PR merges, the dev set
        # gates the freeze/unfreeze. A flat list -> both accessors return it (back-compat).
        pr_req = config_lib.pr_required_checks(cfg)
        dev_req = config_lib.dev_required_checks(cfg)
        rc_union = sorted(set(pr_req) | set(dev_req))
        # The PR set is the mechanical ship gate (§4.3) — adoption requires at least one PR-required
        # check. The dev set MAY be empty (a repo whose CI runs on PRs only, never on dev push).
        if isinstance(cfg.get("required_checks"), dict):
            disp = ("PR: " + (", ".join(pr_req) or "(none)")
                    + " | dev: " + (", ".join(dev_req) or "(none)"))
        else:
            disp = ", ".join(pr_req)
        check("required_checks", bool(pr_req),
              "EMPTY — a repo with no CI check enforcing its tests has no mechanical "
              "ship gate (§4.3); adoption requires at least one PR-required check" if not pr_req
              else disp)

    gh_ok = gh.probe()
    check("gh (reachable + authenticated)", gh_ok)
    if cfg is not None and gh_ok:
        have = gh.labels()
        missing = [n for n, _, _ in LABELS if n not in have]
        check("labels (§C.2 set)", not missing,
              ("missing: " + ", ".join(missing)) if missing else "all present")

    # Issue #28: the worktree base is origin/<dev_branch>. If that branch does not exist on the
    # remote, EVERY launch dies at worktree creation, delivery never verifies, and the issue parks
    # with a misleading "is the launch shim installed?" memo. Catch it here, at adoption time, and
    # NAME the branch. Gated on gh_ok so a full gh outage skips the check entirely; a transient blip
    # DURING the branches call reads conservatively as "missing" (a re-runnable false FAIL on this
    # human-run check — the safe direction, see gh.branch_exists). adopt detects the default branch;
    # this validates whatever dev_branch the config actually holds.
    if cfg is not None and gh_ok:
        dev = cfg.get("dev_branch") if isinstance(cfg.get("dev_branch"), str) else "main"
        dev_ok = gh.branch_exists(dev)
        check(f"dev_branch '{dev}' exists on origin", dev_ok,
              "" if dev_ok else
              f"origin has no '{dev}' branch — every worktree bases off origin/{dev}, so launches "
              f"fail before Claude starts. Set dev_branch to the repo's default (superlooper adopt "
              f"detects it) and re-run doctor")

    # Issue #26: cross-check every required_checks NAME against what the repo has actually reported
    # (recent PRs + the dev branch). A name reported nowhere reads as pending forever — a green PR
    # that never merges — and the runner has no way to know it is a typo vs a genuinely-slow check.
    # Catch it here, at adoption time, with a case/shape hint.
    names_failed = False
    if cfg is not None and gh_ok and rc_union:
        dev = cfg.get("dev_branch") if isinstance(cfg.get("dev_branch"), str) else "main"
        pr_set, dev_set = set(pr_req), set(dev_req)
        pr_names = gate.check_names(gh.recent_pr_check_entries())
        dev_names = gate.check_names(gh.branch_checks(dev))
        # Audit every DECLARED name (the union of both surfaces) against what each surface reports.
        # Which set a name belongs to then decides whether a single-surface report is a problem or
        # exactly what the split intends (issue #52). audit_required_checks stays surface-symmetric;
        # the doctor owns the set-membership interpretation.
        audit = gate.audit_required_checks(rc_union, pr_names, dev_names)

        def _named(results):
            parts = []
            for r in results:
                hint = f" (did you mean {r['hint']!r}?)" if r.get("hint") else ""
                parts.append(f"{r['name']}{hint}")
            return ", ".join(parts)

        if not audit["observed"]:
            # no CI history to cross-check against (fresh repo, or gh has no PR/dev checks yet):
            # WARN, never a hard FAIL — the names cannot be proven wrong, only unverified.
            print("  WARN required_checks names — no checks observed on recent PRs or the "
                  f"'{dev}' branch yet; cannot verify the names (fresh repo?). Re-run doctor "
                  "after the first CI run.")
        else:
            results = audit["results"]
            # A name reported on NEITHER surface is a typo / never-wired check (FAIL), whatever set.
            unreported = [r for r in results if r["status"] == "unreported"]
            # dev_gap: a DEV-required name that reports on PRs but NEVER on the dev branch (status
            # pr_only) — the dev-side poll reads pending forever, so a mainline freeze never lifts
            # (the 2026-07-09 incident). Under the split a PR-only check EXCLUDED from the dev set is
            # NOT flagged — that exclusion is the whole point of issue #52.
            dev_gap = [r for r in results if r["name"] in dev_set and r["status"] == "pr_only"]
            # pr_gap: a PR-required name that reports on the dev branch but NEVER on a PR (status
            # dev_only) — every PR reads pending forever, so a green PR never merges (Codex R1).
            pr_gap = [r for r in results if r["name"] in pr_set and r["status"] == "dev_only"]
            # Each surface-gap FAILs only when the OTHER surface has reported checks (so the absence
            # is real evidence), else it degrades to a WARN.
            if unreported:
                names_failed = True
                check("required_checks names", False,
                      "reported on NO recent PR or the dev branch: " + _named(unreported))
            if dev_gap and audit["dev_observed"]:
                names_failed = True
                check(f"required_checks on '{dev}'", False,
                      "dev-required but reports on PRs and NEVER on the dev branch: " + _named(dev_gap)
                      + f" — the dev-side check poll reads pending forever; ensure the check's "
                      f"workflow triggers on push to '{dev}' (or drop it from the dev-required set)")
            elif dev_gap:
                print(f"  WARN required_checks on '{dev}' — {_named(dev_gap)} reports on PRs but "
                      f"the '{dev}' branch has no check history yet to confirm it runs there; "
                      "re-check after a dev CI run.")
            if pr_gap and audit["pr_observed"]:
                names_failed = True
                check("required_checks on PRs", False,
                      "PR-required but reports on the dev branch and NEVER on a PR: " + _named(pr_gap)
                      + " — every PR reads pending forever, so a green PR never merges; ensure the "
                      "check's workflow triggers on pull_request")
            elif pr_gap:
                print("  WARN required_checks on PRs — " + _named(pr_gap) + " reports on the "
                      f"'{dev}' branch but no recent PR has reported checks yet to confirm it runs "
                      "there; re-check after a PR CI run.")
            if not (unreported or dev_gap or pr_gap):
                print("  ok   required_checks names — every name reports on its expected surface(s)")

    cmux = os.environ.get("SL_CMUX", "/Applications/cmux.app/Contents/Resources/bin/cmux")
    check("cmux binary", os.path.exists(cmux), cmux)
    check("jq", shutil.which("jq") is not None, "pretrust.sh needs it")
    shim = os.path.join(os.path.expanduser("~"), ".superlooper", "launch-shim.zsh")
    check("launch shim installed", os.path.exists(shim),
          shim if os.path.exists(shim) else f"{shim} missing — run bin/install-launch-shim.sh")
    settings = _read(os.path.join(os.path.expanduser("~"), ".claude", "settings.json")) or ""
    check("Claude activity hooks registered", "activity-hook.sh" in settings
          and "stop-hook.sh" in settings,
          "~/.claude/settings.json must register activity-hook.sh (PostToolUse) and "
          "stop-hook.sh (Stop) — bin/install.sh does this" if "activity-hook.sh" not in settings
          else "")
    codex_home = os.environ.get("CODEX_HOME") or os.path.join(os.path.expanduser("~"), ".codex")
    codex_hooks = _read(os.path.join(codex_home, "hooks.json")) or ""
    codex_ok = "activity-hook.sh" in codex_hooks and "stop-hook.sh" in codex_hooks
    print("  " + ("ok   " if codex_ok else "WARN ")
          + "Codex activity hooks registered"
          + ("" if codex_ok else
             f" — {codex_home}/hooks.json missing superlooper hooks; needed only for --agent codex "
             "(bin/install.sh registers them)"))

    if failures:
        print(f"\nDOCTOR FAILED: {', '.join(failures)}")
        if "required_checks" in failures:
            print(_CHECKS_REQUIREMENT)
        if names_failed:
            print(_CHECKS_NAMES_REQUIREMENT)
        return 1
    print("\nall checks passed")
    return 0


# ------------------------------- shared report I/O -------------------------------

def _read_json_file(path, default):
    """Tolerant read for the state files the reports consume: missing -> default; present but
    unparseable -> {} (existence still counts, e.g. an unreadable freeze marker reads as frozen)."""
    txt = _read(path)
    if txt is None:
        return default
    try:
        v = json.loads(txt)
    except ValueError:
        return {}
    return v


def _ledger_map(home):
    """The flat accepted-failure map (ledger.json at the state-home root). Fail closed to {}."""
    v = _read_json_file(os.path.join(home, "ledger.json"), {})
    return v if isinstance(v, dict) else {}


_MISSING = object()


def _frozen_view(home):
    # Existence = frozen (fail closed). Distinguish MISSING (flowing) from PRESENT-but-not-a-proper
    # dict (a corrupt/empty/wrong-typed marker still means frozen — matching runner.py's _read_json
    # posture, so the two morning-report entry points agree).
    v = _read_json_file(os.path.join(home, "state", "merges_frozen.json"), _MISSING)
    if v is _MISSING:
        return None
    return v if isinstance(v, dict) and v else {"reason": "merges_frozen.json present but unreadable"}


def _ready_queue():
    """The waiting queue for the report: open `agent-ready` issues not yet claimed. gh reads fail
    closed to [] (a GitHub blip renders an honest empty queue, never a crash)."""
    out = []
    for raw in gh.ready_issues():
        p = issues_lib.parse_issue(raw)
        if "in-progress" not in (p.get("labels") or []):
            out.append({"num": p.get("num"), "title": p.get("title")})
    out.sort(key=lambda q: q["num"] if isinstance(q.get("num"), int) else 1 << 30)
    return out


# ------------------------------- morning-report -------------------------------

def cmd_morning_report(args):
    cfg = _load_config(args.repo)
    home = str(config_lib.state_home(cfg))
    date = time.strftime("%Y-%m-%d", time.localtime())
    view = {"date": date, "now": time.time(), "frozen": _frozen_view(home),
            "queue": _ready_queue(), "usage": None,
            # Installed-engine publish drift (issue #39): computed here (git is impure; report.py
            # stays pure). engine_drift never raises and skips cleanly when there is no source
            # checkout, so a plain adopted repo simply carries no drift notice.
            "engine_drift": stack_doctor.engine_drift(
                repo_path=args.repo, dev_branch=cfg.get("dev_branch"))}
    text = report.morning(journal.read(home), view, _ledger_map(home), cfg)
    out_dir = os.path.join(home, "reports")
    os.makedirs(out_dir, exist_ok=True)
    out_path = os.path.join(out_dir, f"morning-{date}.md")
    with open(out_path, "w") as f:
        f.write(text)
    summary = next((ln for ln in text.splitlines()
                    if ln.strip() and not ln.startswith("#")), "morning report ready")
    outcome = notify.send(cfg, f"superlooper morning report — {date}", summary)
    print(f"wrote {out_path}\nnotify: {outcome}")
    return 0


# ------------------------------- nightly QA -------------------------------

NIGHTLY_TIMEOUT = 3600      # the browser suite can be long; still bounded so a hang can't wedge.


def _make_nightly_worktree(repo, wt, dev):
    """A fresh DETACHED checkout of origin/<dev> — the nightly runs against current dev, isolated
    from any in-flight lane. Cleans a leftover from a crashed run first. False on any git failure.
    (SL_NIGHTLY_WORKTREE bypasses this for tests/sim, the same way SL_FAKE_USAGE bypasses usage.)"""
    gitops.worktree_remove(repo, wt)
    if not gitops.fetch(repo):
        return False
    try:
        r = subprocess.run(["git", "-C", repo, "worktree", "add", "--detach", wt,
                            f"origin/{dev}"], capture_output=True, text=True, timeout=120)
    except (OSError, subprocess.TimeoutExpired):
        return False
    return r.returncode == 0


def _run_suite(cmd, worktree, results_glob):
    """Run qa.nightly_cmd in the worktree, then parse the JUnit it produced. Returns
    (cmd_rc, parse_result). A missing binary / timeout is a nonzero rc, never a raise."""
    try:
        subprocess.run(["bash", "-lc", cmd], cwd=worktree, capture_output=True,
                       text=True, timeout=NIGHTLY_TIMEOUT)
        rc = 0
    except subprocess.TimeoutExpired:
        rc = 124
    except OSError:
        rc = 127
    texts = []
    if isinstance(results_glob, str) and results_glob.strip():
        for p in sorted(glob.glob(os.path.join(worktree, results_glob))):
            t = _read(p)
            if t is not None:
                texts.append(t)
    return rc, nightly_lib.parse_junit(texts)


def _file_fix_issues(home, failures, dev, operator):
    """File one standing-rule fix issue per DISTINCT persistent failure, deduped by fingerprint:
    skip a fp already tracked in state/fix_issues.json, and reconcile against an open
    auto-approved:nightly-red issue whose body already carries the fp marker (the same crash-window
    dedup the runner's _exec_file_fix_issue does — a nightly-filed and a runner-filed issue for one
    breakage stay one issue). Returns the issue numbers now tracking these failures."""
    path = os.path.join(home, "state", "fix_issues.json")
    filed_map = _read_json_file(path, {})
    filed_map = filed_map if isinstance(filed_map, dict) else {}
    open_bodies = [(it["number"], it["body"]) for it in gh.open_issues("auto-approved:nightly-red")
                   if isinstance(it, dict) and isinstance(it.get("body"), str)
                   and type(it.get("number")) is int]
    tracking, seen = [], set()
    for f in failures:
        fp = f.get("fp")
        if not fp or fp in seen:
            continue
        seen.add(fp)
        if fp in filed_map:
            tracking.append(filed_map[fp])
            continue
        marker = f"Failure fingerprint: `{fp}`"
        hit = next((num for num, body in open_bodies if marker in body), None)
        if hit is not None:
            filed_map[fp] = hit
            tracking.append(hit)
            continue
        issue = nightly_lib.fix_issue(f, dev, operator)
        num = gh.create_issue(issue["title"], issue["body"], labels=issue["labels"])
        if num is None:
            continue                     # gh failed; the next nightly re-files (idempotent by fp)
        filed_map[fp] = num
        tracking.append(num)
    loopstate.save(path, filed_map)
    return tracking


def cmd_nightly(args):
    cfg = _load_config(args.repo)
    home = str(config_lib.state_home(cfg))
    os.makedirs(os.path.join(home, "state"), exist_ok=True)
    qa = cfg.get("qa") if isinstance(cfg.get("qa"), dict) else {}
    cmd = qa.get("nightly_cmd")
    date = time.strftime("%Y-%m-%d", time.localtime())
    now = time.time()
    if not (isinstance(cmd, str) and cmd.strip()):
        print("qa.nightly_cmd is null — the browser suite isn't wired for this repo yet; "
              "nothing to run. (It's built collaboratively first; the config then points at it.)")
        return 0
    dev = cfg.get("dev_branch") if isinstance(cfg.get("dev_branch"), str) else "main"
    results_glob = qa.get("results_glob")

    injected = os.environ.get("SL_NIGHTLY_WORKTREE")
    wt = injected or os.path.join(home, "nightly-worktree")
    made = False
    if not injected:
        if not _make_nightly_worktree(args.repo, wt, dev):
            # can't even build the checkout: honest failure, journal + notify, never a green.
            journal.append(home, {"act": "nightly", "date": date, "parse_error": True,
                                  "green": False, "flakes": 0, "persistent": 0, "filed": [],
                                  "note": "could not create nightly worktree", "outcome": "ok"}, now)
            notify.send(cfg, f"superlooper nightly could not start ({date})",
                        f"failed to create a fresh worktree of origin/{dev} — see the nightly log.")
            print("nightly: could not create the worktree", file=sys.stderr)
            return 1
        made = True

    try:
        rc1, p1 = _run_suite(cmd, wt, results_glob)
        # Persist the parsed run so `promote-report --use-latest-nightly` can reuse it without
        # re-running the (long) suite. Written for BOTH the ok and the could-not-parse paths.
        loopstate.save(os.path.join(home, "state", "last_nightly.json"),
                       {"date": date, "ok": p1["ok"], "failures": p1["failures"]})
        if not p1["ok"]:
            # Broken/empty/missing results are NEVER a silent green: journal parse_error (the
            # morning report renders it honestly) + notify + nonzero exit. We do NOT touch the
            # shared ALERT or freeze marker here — those are the runner's to own (it would clear a
            # nightly-written ALERT within a tick); the durable signals are this journal record
            # and the immediate push.
            journal.append(home, {"act": "nightly", "date": date, "parse_error": True,
                                  "green": False, "flakes": 0, "persistent": 0, "filed": [],
                                  "cmd_rc": rc1, "outcome": "ok"}, now)
            notify.send(cfg, f"superlooper nightly — could not parse results ({date})",
                        f"qa.nightly_cmd exited {rc1}; no parseable JUnit at {results_glob!r}. "
                        "The nightly could not confirm dev is green — check the nightly log.")
            print(f"nightly: could not parse results (cmd rc={rc1})", file=sys.stderr)
            return 1

        run2 = None
        if qa.get("retry_once", True) and p1["failures"]:
            _, p2 = _run_suite(cmd, wt, results_glob)
            # An unparseable retry can't prove a flake, so treat run1's failures as persistent
            # (conservative): pass them as run2 so the intersection keeps them.
            run2 = p2["failures"] if p2["ok"] else p1["failures"]

        accepted = set(ledger_lib.load(home).keys())
        quarantine = qa.get("quarantine") if isinstance(qa.get("quarantine"), list) else []
        result = nightly_lib.classify(p1["failures"], run2, quarantine, accepted)
        to_file = result["to_file"]

        frozen_path = os.path.join(home, "state", "merges_frozen.json")
        filed = []
        if to_file:
            # Claim freeze OWNERSHIP with source="nightly" (Codex R2 C2), OVERWRITING any existing
            # marker: a red nightly is slow to recover (once a night), so it must be sticky against
            # the runner's dev-green unfreeze. If a dev-check freeze was the only cause and it
            # recovers first, the runner re-freezes within a tick — so overwriting is the safe
            # direction (stays frozen until the slow condition clears).
            loopstate.save(frozen_path,
                           {"reason": f"nightly red: {len(to_file)} persistent failure(s)",
                            "fingerprint": to_file[0]["fp"], "since": now, "source": "nightly"})
            filed = _file_fix_issues(home, to_file, dev, config_lib.operator(cfg))
        else:
            # A green nightly clears ONLY a nightly-owned freeze — never a runner dev-check freeze
            # (which the runner clears when dev checks go green).
            cur = _read_json_file(frozen_path, None)
            if isinstance(cur, dict) and cur.get("source") == "nightly":
                try:
                    os.remove(frozen_path)
                except OSError:
                    pass

        green = not to_file
        journal.append(home, {"act": "nightly", "date": date, "green": green,
                              "flakes": len(result["flakes"]), "persistent": len(to_file),
                              "accepted": len(result["accepted"]),
                              "quarantined": len(result["quarantined"]),
                              "filed": filed, "parse_error": False, "cmd_rc": rc1,
                              "outcome": "ok"}, now)

        if to_file:
            shown = ", ".join(f"#{n}" for n in filed) or "(dedup: already open)"
            notify.send(cfg, f"superlooper nightly RED ({date})",
                        f"{len(to_file)} persistent failure(s); merges frozen, fix issue(s): {shown}")
            print(f"nightly RED: {len(to_file)} persistent, filed {filed or '(deduped)'}, "
                  f"merges frozen ({len(result['flakes'])} flake(s), "
                  f"{len(result['accepted'])} accepted, {len(result['quarantined'])} quarantined)")
        else:
            print(f"nightly green ({len(result['flakes'])} flake(s), "
                  f"{len(result['accepted'])} accepted-ledger, "
                  f"{len(result['quarantined'])} quarantined)")
        return 0
    finally:
        if made:
            gitops.worktree_remove(args.repo, wt)


# ------------------------------- promotion evidence + accept-failure -------------------------------

def _open_issue_summary():
    """Open issues for the promotion report's open-issue section: the approved queue + everything
    in flight, deduped, oldest-first. gh fails closed to [] (a blip renders an honest empty list)."""
    seen, out = set(), []
    for label in ("agent-ready", "in-progress"):
        for raw in gh.open_issues(label):
            p = issues_lib.parse_issue(raw)
            num = p.get("num")
            if isinstance(num, int) and num not in seen:
                seen.add(num)
                out.append({"num": num, "title": p.get("title"), "labels": p.get("labels")})
    out.sort(key=lambda i: i["num"])
    return out


def cmd_promote_report(args):
    cfg = _load_config(args.repo)
    home = str(config_lib.state_home(cfg))
    date = time.strftime("%Y-%m-%d", time.localtime())
    qa = cfg.get("qa") if isinstance(cfg.get("qa"), dict) else {}

    if args.use_latest_nightly:
        ln = _read_json_file(os.path.join(home, "state", "last_nightly.json"), None)
        if not isinstance(ln, dict):
            print("no stored nightly results (state/last_nightly.json) — run `superlooper nightly` "
                  "first, or omit --use-latest-nightly to run the suite now.", file=sys.stderr)
            return 1
        # ok must be EXACTLY True — a corrupt/hand-edited cache with a truthy wrong-typed value
        # ("false", {}, 1) must never render as parsed evidence (silent all-clear). Anything but
        # True falls to report.promotion's could-not-parse path (Codex R2 C3).
        suite = {"ok": ln.get("ok") is True,
                 "failures": ln.get("failures") if isinstance(ln.get("failures"), list) else [],
                 "source": f"latest nightly {ln.get('date')}"}
    else:
        cmd = qa.get("nightly_cmd")
        if not (isinstance(cmd, str) and cmd.strip()):
            print("qa.nightly_cmd is null — nothing to run. Use --use-latest-nightly, or wire the "
                  "suite in .superlooper/config.json.", file=sys.stderr)
            return 1
        dev = cfg.get("dev_branch") if isinstance(cfg.get("dev_branch"), str) else "main"
        injected = os.environ.get("SL_NIGHTLY_WORKTREE")
        wt = injected or os.path.join(home, "promote-worktree")
        made = False
        if not injected:
            if not _make_nightly_worktree(args.repo, wt, dev):
                print("could not create the suite worktree", file=sys.stderr)
                return 1
            made = True
        try:
            _, p = _run_suite(cmd, wt, qa.get("results_glob"))
        finally:
            if made:
                gitops.worktree_remove(args.repo, wt)
        suite = {"ok": p["ok"], "failures": p["failures"], "source": "fresh suite"}

    prod = cfg.get("prod_branch")
    dev = cfg.get("dev_branch") if isinstance(cfg.get("dev_branch"), str) else "main"
    result = gh.compare(prod, dev) if isinstance(prod, str) and prod.strip() else None
    compare = {"prod_branch": prod, "dev_branch": dev, "result": result}

    text = report.promotion(date, suite, ledger_lib.load(home), compare,
                            _open_issue_summary(), cfg)
    out_dir = os.path.join(home, "reports")
    os.makedirs(out_dir, exist_ok=True)
    out_path = os.path.join(out_dir, f"promotion-{date}.md")
    with open(out_path, "w") as f:
        f.write(text)
    outcome = notify.send(cfg, f"superlooper promotion evidence — {date}",
                          "promotion evidence ready — no verdict, your call (Gate 2).")
    print(f"wrote {out_path}\nnotify: {outcome}")
    return 0


def cmd_accept_failure(args):
    cfg = _load_config(args.repo)
    home = str(config_lib.state_home(cfg))
    fp = args.fingerprint
    if not (isinstance(fp, str) and fp.strip()):
        print("accept-failure needs a fingerprint (copy it from a promotion report).",
              file=sys.stderr)
        return 2
    os.makedirs(home, exist_ok=True)             # a first-ever accept may precede any runner run
    ledger_lib.accept(home, fp.strip(), note=args.note)
    note = f' — "{args.note}"' if args.note else ""
    print(f"accepted failure {fp.strip()}{note}\n"
          "This acceptance persists (one approval, ever) and folds the failure away in future "
          "promotion reports.")
    return 0


# ------------------------------- tidy -------------------------------
# `superlooper tidy` closes the cmux windows of FINISHED sessions. It is William's explicit word,
# never automatic (V1 'nothing auto-closed' — DRYRUN 2026-07-03): a real claude worker idles at
# its prompt forever after finishing (D4) and never self-closes, so windows pile up. Safe to run
# while the runner is live — the pure selector (tidy.closable) never picks an in-flight or
# in-between-gate lane, so a close can only ever land on a finished, idle session.

def _panes_dir(home):
    return os.path.join(home, "state", "panes")


def _recorded_windows(home):
    """The iids that have a recorded cmux window: a pane marker file state/panes/<iid> (an exact
    `i<N>` name — the `.ws` sidecar is skipped). Missing dir / unreadable -> empty set."""
    out = set()
    try:
        for name in os.listdir(_panes_dir(home)):
            if re.fullmatch(r"i\d+", name):
                out.add(name)
    except OSError:
        pass
    return out


def _snapshot(home, iid):
    """(surface, ws) read from disk NOW. Captured at LIST time — the close then targets exactly
    the window shown to William, never a re-read that a relaunch during the y/N wait could have
    redirected to a fresh, LIVE surface (Codex cross-review round 1: the never-close-in-flight
    property must survive a concurrent re-approval)."""
    panes = _panes_dir(home)
    return ((_read(os.path.join(panes, iid)) or "").strip(),
            (_read(os.path.join(panes, f"{iid}.ws")) or "").strip())


def _close_window(cmux, home, iid, surface, ws, *, cleanup):
    """Best-effort close of the SNAPSHOTTED surface (rc IGNORED — a dead surface is a silent
    no-op). Then, ONLY when `cleanup` is set, clear iid's pane markers + singleton lock — the
    runner's _close_stale_session close (runner.py), copied deliberately (runner.py is read-only
    here; a parallel session owns it — dedup noted as a follow-up).

    Why the close targets the SNAPSHOT surface and not a fresh re-read: the snapshot was taken
    when the window was listed, so if a relaunch replaced this session while tidy ran, we close
    the OLD (now-dead) surface — a harmless no-op — and NEVER the new, LIVE one. tidy can't close
    an in-flight window.

    Why cleanup is gated (Codex cross-review rounds 1-2): pane markers/lock are NOT under any lock
    tidy can take (the runner writes them from the shell launch stack), so a read-then-remove can
    never be made atomic against a concurrent relaunch. The airtight fix is structural — `cleanup`
    is set ONLY for a status that can NEVER relaunch (merged; see tidy.REAPPROVABLE), so there is
    no concurrent writer and the removal is race-free. For a re-approvable status tidy closes the
    window but leaves the markers/lock to the runner, whose _close_stale_session frees them on the
    next relaunch (and _live_lock_ids ignores a dead-PID lock meanwhile) — so tidy never frees a
    live worker's singleton lock. Freeing a merged session's stale lock mirrors _close_stale_session
    (the finished-but-alive session held it — D4)."""
    if surface:
        args = [cmux, "close-surface", "--surface", surface]
        if ws:
            args += ["--workspace", ws]
        try:
            subprocess.run(args, capture_output=True, text=True, timeout=_CLOSE_TIMEOUT)
        except (OSError, subprocess.TimeoutExpired):
            pass                                  # best-effort; a close failure never wedges tidy
    if not cleanup:
        return
    panes = _panes_dir(home)
    for p in (os.path.join(panes, iid), os.path.join(panes, f"{iid}.ws"),
              os.path.join(home, "state", f"worker.{iid}.lock")):
        try:
            os.remove(p)
        except OSError:
            pass


def cmd_tidy(args):
    cfg = _load_config(args.repo)
    home = str(config_lib.state_home(cfg))
    try:
        st = loopstate.load(os.path.join(home, "state", "issues.json"))
    except (OSError, ValueError):
        st = {}
    # Guard st ITSELF: a corrupt issues.json can parse as a JSON list/str/number, so st.get would
    # raise before the selector's own guards — fail closed to no issues (nothing to close).
    st = st if isinstance(st, dict) else {}
    issues = st.get("issues") if isinstance(st.get("issues"), dict) else {}
    targets = tidy_lib.closable(issues, _recorded_windows(home), scope_all=args.all)
    scope = "terminal" if args.all else "merged"
    if not targets:
        print(f"tidy: no finished ({scope}) session windows to close.")
        return 0

    # Snapshot each target's surface/ws NOW, before the y/N wait, so the close targets exactly the
    # windows listed here — a relaunch during the wait can't redirect a close onto a live window.
    snaps = [{"id": t["id"], "status": t["status"], **dict(zip(("surface", "ws"),
              _snapshot(home, t["id"])))} for t in targets]
    print(f"tidy will close {len(snaps)} finished ({scope}) session window(s):")
    for s in snaps:
        print(f"  {s['id']:5} {s['status']:13} {s['surface'] or '(no surface)'}")
    if args.dry_run:
        print("dry-run: nothing closed.")
        return 0
    if not args.yes:
        try:
            reply = input("close these windows? [y/N] ").strip().lower()
        except EOFError:
            reply = ""
        if reply not in ("y", "yes"):
            print("aborted — nothing closed.")
            return 0

    cmux = os.environ.get("SL_CMUX", _CMUX_DEFAULT)
    reconciled = []
    for s in snaps:
        # cleanup (remove markers+lock) ONLY for a status that can never relaunch — merged. A
        # re-approvable session's markers/lock stay the runner's to reconcile (race-free by
        # construction; see _close_window).
        cleanup = s["status"] not in tidy_lib.REAPPROVABLE
        _close_window(cmux, home, s["id"], s["surface"], s["ws"], cleanup=cleanup)
        if not cleanup:
            reconciled.append(s["id"])
    print(f"closed {len(snaps)} window(s)." + (
        f" {len(reconciled)} re-approvable session(s) left for the runner to reconcile "
        f"({', '.join(reconciled)})." if reconciled else ""))
    return 0


# ------------------------------- janitor -------------------------------
# `superlooper janitor` (issue #62, spec §8 V2) PROPOSES GitHub-side cleanup and executes ONLY
# what William approves — the same propose/approve word-discipline as tidy, pointed at GitHub
# instead of cmux windows. Three debris classes, each with a one-line why: stale sl/* remote
# branches whose PRs merged or were superseded, PRs labeled `superseded` left open by design
# (§C.4 6b), and parked / needs-william issues gathering dust past janitor.aged_park_days.
# The list / --dry-run changes NOTHING anywhere; approved actions run mechanically and are
# journaled; a refused/failed action is surfaced once and held back (state/janitor_refused.json),
# never silently retried — --retry-refused re-proposes it. There is no schedule wiring for the
# execute path and none may ever be added: proposals may be generated on a schedule, ACTIONS
# only ever on the owner's word.

_REFUSED_FILE = "janitor_refused.json"
_JANITOR_STAMP = "superlooper janitor — approved by the owner: "


def _janitor_loopstate(home):
    """loopstate['issues'] with the fail direction the janitor needs: a MISSING issues.json is
    an honest empty ({} — no lane has ever run, nothing to exclude), but a PRESENT-yet-unreadable
    or wrong-typed one is None — the caller must refuse to propose ANYTHING, because nothing is
    provably idle. (Compare tidy, where unreadable state fails closed to 'close nothing' the
    same way — here 'nothing' means 'propose nothing'.)"""
    path = os.path.join(home, "state", "issues.json")
    try:
        st = loopstate.load(path)
    except FileNotFoundError:
        return {}                # genuinely absent: no lane has ever run
    except (OSError, ValueError):
        return None              # present but unreadable (EPERM, corrupt, ...): refuse
    if not isinstance(st, dict) or not isinstance(st.get("issues"), dict):
        return None
    return st["issues"]


def _janitor_refused_read(path):
    """The hold-back map, strictly: a MISSING file -> {} (nothing ever refused), but PRESENT
    and unreadable / wrong-typed -> None — the caller must refuse to run. Reading corrupt or
    permission-blocked hold-back state as empty would silently re-propose every previously
    refused action (cross-review rounds 1-2, C2). Opened directly, not via _read(): _read
    collapses EVERY OSError to None, and only ENOENT may mean 'nothing ever refused' —
    an EPERM on a present file must refuse, not blank the map."""
    try:
        with open(path) as f:
            txt = f.read()
    except FileNotFoundError:
        return {}
    except OSError:
        return None
    try:
        v = json.loads(txt)
    except ValueError:
        return None
    return v if isinstance(v, dict) else None


def _janitor_fetch(ls_issues):
    """One fetched snapshot of everything janitor.propose selects from. Every gh read fails
    closed to empty, so a GitHub blip shrinks the sweep toward proposing NOTHING, never toward
    proposing more."""
    sl = {b: tip for b, tip in gh.remote_branches().items()
          if isinstance(b, str) and b.startswith(janitor_lib.BRANCH_PREFIX)}
    parked = []
    for label in janitor_lib.PARK_LABELS:
        parked += gh.open_issues_activity(label)
    return {"branches": sl,
            "branch_prs": {b: gh.pr_for_branch(b) for b in sl},
            "superseded_prs": gh.open_prs_labeled(janitor_lib.SUPERSEDED_LABEL),
            "parked_issues": parked,
            "ls_issues": ls_issues}


def _janitor_line(p):
    """One proposal, one line, why included — exactly what William approves."""
    if p["kind"] == "branch":
        what = f"delete branch {p['target']}"
    elif p["kind"] == "pr":
        head = f" ({p['head']})" if p.get("head") else ""
        what = f"close PR #{p['target']}{head}"
    else:
        title = p.get("title") or ""
        what = f"close issue #{p['target']}" + (f" {title[:60]!r}" if title else "")
    return f"  {what} — {p['why']}"


def _janitor_execute(p):
    """One approved action -> (ok, reason). Mechanical verbs only — delete ref / close PR /
    close issue — each leaving an audit comment where a comment is possible."""
    if p["action"] == "delete-branch":
        ok = gh.delete_branch(p["target"])
    elif p["action"] == "close-pr":
        ok = gh.close_pr(p["target"], comment=_JANITOR_STAMP + p["why"])
    elif p["action"] == "close-issue":
        ok = gh.close_issue(p["target"], comment=_JANITOR_STAMP + p["why"])
    else:
        return False, f"unknown action {p['action']!r}"      # unreachable; fail closed anyway
    return ok, ("" if ok else "gh refused the write (or was unreachable)")


def cmd_janitor(args):
    cfg = _load_config(args.repo)
    home = str(config_lib.state_home(cfg))
    days = cfg["janitor"]["aged_park_days"]
    dev = cfg.get("dev_branch") if isinstance(cfg.get("dev_branch"), str) else "main"

    ls = _janitor_loopstate(home)
    if ls is None:
        print("janitor: state/issues.json exists but is unreadable — nothing is provably "
              "idle, so nothing will be proposed. Fix or remove it, then re-run.",
              file=sys.stderr)
        return 1

    refused_path = os.path.join(home, "state", _REFUSED_FILE)
    refused_map = _janitor_refused_read(refused_path)
    if refused_map is None:
        print(f"janitor: state/{_REFUSED_FILE} exists but is unreadable — running would "
              "silently drop every held-back refused action. Fix or remove it, then re-run.",
              file=sys.stderr)
        return 1
    refused_keys = set() if args.retry_refused else set(refused_map)

    result = janitor_lib.propose(**_janitor_fetch(ls), now=time.time(), aged_park_days=days,
                                 refused=refused_keys, dev_branch=dev)
    props, held = result["proposals"], result["refused"]
    held_note = (f"({len(held)} previously refused action(s) held back — --retry-refused "
                 f"re-proposes them; see state/{_REFUSED_FILE})" if held else "")

    if not props:
        print("janitor: nothing to propose — no GitHub-side debris found."
              + (" " + held_note if held_note else ""))
        return 0

    print(f"janitor proposals ({len(props)}) — nothing executes without your approval:")
    for p in props:
        print(_janitor_line(p))
    if held_note:
        print(held_note)
    if args.dry_run:
        print("dry-run: nothing executed, nothing written.")
        return 0
    if not args.yes:
        try:
            reply = input(f"execute these {len(props)} action(s)? [y/N] ").strip().lower()
        except EOFError:
            reply = ""
        if reply not in ("y", "yes"):
            print("aborted — nothing executed.")
            return 0

    # William's word is given. Re-fetch and re-derive NOW — the y/N wait can be minutes, and
    # the world may have moved (a mid-wait re-approval must never get its branch deleted) — and
    # execute only what is STILL eligible. An item that dropped out is skipped, never forced.
    ls2 = _janitor_loopstate(home)
    if ls2 is None:
        print("janitor: state/issues.json became unreadable during the wait — refusing to "
              "execute (nothing is provably idle anymore).", file=sys.stderr)
        return 1
    fresh = janitor_lib.propose(**_janitor_fetch(ls2), now=time.time(), aged_park_days=days,
                                refused=set(), dev_branch=dev)
    to_run, skipped = janitor_lib.reconcile(props, fresh["proposals"])
    now = time.time()
    executed = failed = 0
    for p in skipped:
        print(f"  skip  {p['key']} — no longer eligible (state moved during the wait)")
        journal.append(home, {"act": "janitor", "action": p["action"], "target": p["target"],
                              "outcome": "skipped",
                              "why": "no longer eligible at execution time"}, now)
    for p in to_run:
        ok, reason = _janitor_execute(p)
        journal.append(home, {"act": "janitor", "action": p["action"], "target": p["target"],
                              "why": p["why"], "outcome": "ok" if ok else "fail",
                              **({"reason": reason} if reason else {})}, now)
        if ok:
            refused_map.pop(p["key"], None)
            executed += 1
            print(f"  ok    {p['key']}")
        else:
            refused_map[p["key"]] = {"reason": reason, "ts": now}
            failed += 1
            print(f"  FAIL  {p['key']} — {reason}; held back from future sweeps "
                  f"(--retry-refused re-proposes)")
    # A refusal is NEVER pruned on a key's absence from a sweep: absence is not proof the
    # debris is gone — a transient gh blip produces the same absence (every read fails closed
    # to empty), and pruning on it would silently drop the hold-back and let a later sweep
    # retry a refused action without --retry-refused (cross-review round 1, C1). An entry
    # clears ONLY via a later successful execution (the pop above); a moot entry lingers
    # harmlessly (held-back keys that never re-propose never act). Only the execute path
    # writes state; list/--dry-run changes nothing anywhere.
    os.makedirs(os.path.dirname(refused_path), exist_ok=True)   # a first sweep may precede any runner run
    loopstate.save(refused_path, refused_map)
    print(f"janitor: {executed} executed, {failed} failed, {len(skipped)} skipped.")
    return 1 if failed else 0


# ------------------------------- watchdog (issue #66) -------------------------------
# `superlooper watchdog` is ONE mechanical health check — the unattended-debugger fallback.
# No LLM call exists anywhere on this path and it makes no repair decisions: it reads the
# engine's own signals (state/runner.heartbeat, state/ALERT, the no-progress shape), and per
# lib/watchdog.py's episode rules notifies -> waits the grace -> launches ONE sl-debugger
# session through the SAME interactive launch shim workers use (launch-session.sh --cwd,
# never a headless `claude -p` — owner billing rule). Run it on an interval via
# templates/launchd.watchdog.plist (it may run under launchd: a check needs no cmux pane;
# the rare launch targets the RUNNER's recorded anchor and fails loudly when none resolves).
# state/WATCHDOG_OFF disables the whole path; every transition is journaled.

WATCHDOG_LAUNCH_TIMEOUT = 180   # launch-session.sh verifies delivery within ~30s; generous


def _pid_alive(pid):
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, ValueError, TypeError):
        return False
    except PermissionError:
        return True


def _live_lock(path):
    """A lock file naming a LIVE pid. Unreadable/garbage content reads as dead (reclaimable)."""
    pid = (_read(path) or "").strip()
    return pid.isdigit() and _pid_alive(int(pid))


def _watchdog_acquire_lock(lock_path):
    """Per-state-home singleton acquire — ported from start-session.sh's `ln`-of-temp worker lock.
    We write our pid into a temp file and then HARDLINK it onto the lock: `ln`/O_EXCL fails if the
    lock already exists, so ACQUIRING A FREE SLOT is atomic — of any number of checks racing for an
    absent lock, exactly ONE wins the link and the rest see its live pid and yield. This is the
    guarantee that closes the OLD check-then-write hole (its read-liveness → open(,"w") let a
    launchd firing and a hand-run check BOTH pass the check and BOTH write watchdog.json — the
    duplicate-episode / burned-launch race, issue #92). The pid is present BEFORE the file becomes
    the lock, so there is no empty-content window a racer could misread as stale (start-session.sh's
    codex P1-a lesson). Returns True iff we now hold the lock; False when a LIVE check owns it.

    A dead/garbage holder is reclaimed, GUARDED by a content re-check: remove the lock only if it
    still names that same dead holder, so we don't delete a fresh lock a concurrent claimer won
    between our read and our remove. This guard NARROWS but does not fully eliminate the reclaim
    race (a POSIX file op cannot atomically 'remove-if-content-is-X'); the residual is the same in
    kind as loopstate._acquire's stale-steal and start-session.sh's worker singleton, and it is
    reachable only when a check has already crashed leaving a stale lock AND two more checks race to
    reclaim it AND one is preempted mid-reclaim — a rare cube for a job that fires minutes apart. A
    duplicate episode text or a burned launch attempt (both self-limiting via the episode rails) is
    the worst case, never a corrupt state file."""
    me = str(os.getpid())
    state_dir = os.path.dirname(lock_path) or "."
    for _ in range(50):
        fd, tmp = tempfile.mkstemp(dir=state_dir, prefix="watchdog.", suffix=".lock.tmp")
        try:
            os.write(fd, me.encode())               # full content BEFORE it becomes the lock
        finally:
            os.close(fd)
        linked = False
        try:
            os.link(tmp, lock_path)                 # atomic create-with-content; fails if lock exists
            linked = True
        except FileExistsError:
            pass
        except OSError:
            _rm_quiet(tmp)
            return False                            # a fs that can't link -> yield, never double-run
        finally:
            _rm_quiet(tmp)
        if linked:
            return True
        holder = (_read(lock_path) or "").strip()
        if holder.isdigit() and _pid_alive(int(holder)):
            return False                            # a LIVE check owns it
        # dead/garbage holder -> reclaim, but only if the lock STILL names that same holder (content
        # re-check), so we never remove a fresh lock a concurrent claimer just won between our read
        # and our remove. Then loop: the atomic link above arbitrates the now-free slot.
        if (_read(lock_path) or "").strip() == holder:
            _rm_quiet(lock_path)
    return False


def _watchdog_release_lock(lock_path):
    """Ownership-checked release: remove the lock ONLY if it still names US (start-session.sh's
    release_worker) — after a reclaim race the file may name a different check, and an
    unconditional remove would break the singleton by deleting their lock."""
    if (_read(lock_path) or "").strip() == str(os.getpid()):
        _rm_quiet(lock_path)


def _rm_quiet(path):
    try:
        os.remove(path)
    except OSError:
        pass


def _watchdog_heartbeat(state_dir):
    """Epoch of the last COMPLETED runner tick, or None when the loop never ran here (an
    absent heartbeat is not a stale one) or the file is unreadable/garbage (fail toward
    no-signal: the ALERT/no-progress detectors still stand, and a corrupt heartbeat file
    would otherwise read as an eternal 3am trip)."""
    txt = _read(os.path.join(state_dir, "runner.heartbeat"))
    try:
        return int((txt or "").strip())
    except ValueError:
        return None


def _watchdog_alert(state_dir):
    """The ALERT dict, {} when present-but-unreadable (existence IS the signal — fail
    closed, runner._read_json's posture), None when absent."""
    path = os.path.join(state_dir, "ALERT")
    if not os.path.exists(path):
        return None
    v = _read_json_file(path, {})
    return v if isinstance(v, dict) else {}


def _watchdog_loopstate(state_dir):
    """The persisted issue state (issues.json), or {} when absent/corrupt. Read ONCE per check and
    shared by the lane-occupancy and gh-eligibility views so they see the same disk truth."""
    try:
        return loopstate.load(os.path.join(state_dir, "issues.json"))
    except (OSError, ValueError):
        return {}


def _watchdog_lanes_busy(st, state_dir):
    """Any lane occupied, from DISK truth: an in-flight status in issues.json, or a live
    worker singleton lock for an issue id (a session the state file has not caught up with).
    NB gating/holding statuses hold a territory CLAIM but occupy no lane, so they are NOT
    lanes-busy — the no-progress view respects them through scheduler.launchable instead."""
    import actions
    if actions.lane_state_from(st):
        return True
    try:
        names = os.listdir(state_dir)
    except OSError:
        names = []
    return any(n.startswith("worker.i") and n.endswith(".lock")
               and _live_lock(os.path.join(state_dir, n)) for n in names)


def _watchdog_debugger_live(state_dir):
    """A live unattended sl-debugger session: any worker.d<N>.lock naming a live pid
    (start-session.sh's per-id singleton — the same file that keeps workers single)."""
    try:
        names = os.listdir(state_dir)
    except OSError:
        return False
    return any(n.startswith("worker.d") and n.endswith(".lock")
               and _live_lock(os.path.join(state_dir, n)) for n in names)


def _watchdog_gh_view(cfg, st):
    """(gh_ok, eligible_nums): the no-progress detector's eligibility read — the issues the
    SCHEDULER would launch RIGHT NOW, so every scheduler hold is respected and a designed-safe
    wait can never read as waiting work:
      * agent-ready issues from GitHub, run through the same issues.eligible rule the scheduler
        uses (blocked-by holds, in-progress, parked/needs-owner all excluded);
      * lane capacity + anti-affinity + TERRITORY CLAIMS from issues.json — the #92 fix: a
        gating/holding issue's claim occupies no lane but holds the eligible work behind it.
    gh_ok is False when the view is UNOBSERVABLE, so the caller FREEZES the clocks instead of
    reading a refusal as 'nothing eligible': the probe is down, OR (the #92 trap) the probe
    SUCCEEDS but a list read is REFUSED — read-health `ok` distinguishes that from a genuine
    empty answer (the #21/#61 contract). A clean answered-empty read is observable (gh_ok True)."""
    import actions
    import watchdog as watchdog_lib
    if not gh.probe():
        return False, []
    ready = gh.ready_issues_health()
    closed = gh.closed_issue_nums_health()
    if not ready.ok or not closed.ok:
        return False, []                    # probe ok but a read REFUSED -> unobservable
    parsed = [issues_lib.parse_issue(r) for r in ready.value]
    lane_state = actions.lane_state_from(st)
    claims = actions.territory_claims_from(st)
    return True, watchdog_lib.launchable_nums(parsed, lane_state, cfg, closed.value, claims)


def _watchdog_usage_exhausted():
    """True only when the meter SUCCESSFULLY reads strictly OVER a launch ceiling — the runner's
    designed fail-closed hold. A dark/unreadable meter is False (the #46/#76 asymmetry): it
    must never suppress the detector, especially under launchd where the Keychain read can
    fail. SL_FAKE_USAGE injects the read for tests/simulation, exactly like cmd_run."""
    import watchdog as watchdog_lib
    fake = os.environ.get("SL_FAKE_USAGE")
    try:
        if fake:
            usage = json.loads(fake)
        else:
            import usage as usage_mod
            usage = usage_mod.fetch_claude_usage()
    except Exception:
        return False
    return watchdog_lib.usage_reads_exhausted(usage)


def _watchdog_pane(state_dir):
    """The cmux pane the debugger tab is born in: an explicit $SL_PANE override, else the
    RUNNER's recorded anchor (state/runner.anchor.json — present while a runner is live or
    crashed; a clean stop clears it), else this process's own tab when run by hand inside
    cmux. "" when nothing resolves — the launch then fails loudly, never silently."""
    pane = os.environ.get("SL_PANE") or ""
    if pane.strip():
        return pane.strip()
    anchor = _read_json_file(os.path.join(state_dir, "runner.anchor.json"), None)
    if isinstance(anchor, dict):
        pane = anchor.get("pane")
        if isinstance(pane, str) and pane.strip():
            return pane.strip()
    from runner import detect_self_anchor
    return detect_self_anchor()["pane"]


def _watchdog_launch(repo, cfg, home, state_dir, launch, state):
    """Execute one launch request through the SAME shim stack workers use. Returns the rc
    fed to watchdog.after_launch: 0 only when launch-session.sh VERIFIED delivery."""
    import watchdog as watchdog_lib
    ep = state.get("episode") if isinstance(state.get("episode"), dict) else {}
    wd = cfg.get("watchdog") if isinstance(cfg.get("watchdog"), dict) else {}
    template = _read(os.path.join(_TEMPLATES, "debugger-brief.md")) or ""
    brief = watchdog_lib.render_brief(template, {
        "signals": ", ".join(launch.get("signals") or []),
        "detail": ep.get("detail") or ", ".join(launch.get("signals") or []),
        "authority": launch.get("authority"),
        "allowlist": ", ".join(launch.get("allowlist") or []) or "(none)",
        "state_home": home,
        "repo_path": os.path.abspath(repo),
        "repo_slug": cfg.get("repo"),
        "grace_minutes": wd.get("grace_minutes", 30),
    })
    os.makedirs(os.path.join(home, "briefs"), exist_ok=True)
    with open(os.path.join(home, "briefs", f"{launch['id']}.md"), "w") as f:
        f.write(brief)
    pane = _watchdog_pane(state_dir)
    if not pane:
        print("watchdog: no cmux pane resolves (no $SL_PANE, no recorded runner anchor, not "
              "inside cmux) — cannot launch; notifying instead.", file=sys.stderr)
        return "no_pane"
    models = cfg.get("models") if isinstance(cfg.get("models"), dict) else {}
    script = os.environ.get("SL_LAUNCH_SESSION") or os.path.join(_HERE, "launch-session.sh")
    env = {**os.environ,
           "SL_RUN_ROOT": home, "SL_PANE": pane,
           # the debugger is a hired-judgment seat like the answerer — same model default
           "SL_MODEL": models.get("answerer") or "opus[1m]", "SL_EFFORT": "",
           # PIN the shim verify window (review P1-1): launch-session.sh inherits
           # SL_LAUNCH_VERIFY_SECONDS, and an ambient large value (a debugging export, a
           # LaunchAgent env) would let the launch outlive WATCHDOG_LAUNCH_TIMEOUT — rc=124
           # counts a FAILED attempt while the tab delivers late and a real session starts,
           # so a later check could launch a SECOND session for one episode. 30s is the
           # script's own default and sits far under the 180s timeout.
           "SL_LAUNCH_VERIFY_SECONDS": "30",
           "SL_AGENT": cfg.get("agent") if cfg.get("agent") in ("claude", "codex") else "claude"}
    try:
        r = subprocess.run([script, "--cwd", os.path.abspath(repo), launch["id"]],
                           env=env, capture_output=True, text=True,
                           timeout=WATCHDOG_LAUNCH_TIMEOUT)
    except subprocess.TimeoutExpired:
        return 124
    except OSError:
        return 127
    out = (r.stdout or "") + (r.stderr or "")
    if out.strip():
        print(out.strip())
    return r.returncode


def cmd_watchdog(args):
    import watchdog as watchdog_lib
    cfg = _load_config(args.repo)
    home = str(config_lib.state_home(cfg))
    state_dir = os.path.join(home, "state")
    os.makedirs(state_dir, exist_ok=True)
    now = time.time()

    # Per-state-home singleton: a hand-run check and the launchd firing must not interleave their
    # read-evaluate-write on watchdog.json. Acquired ATOMICALLY (create-with-content via os.link,
    # not the old check-then-write) so two overlapping checks racing to acquire a FREE slot can
    # never both proceed; a dead holder's lock is reclaimed via an atomic os.rename steal (one
    # winner per rename).
    lock = os.path.join(state_dir, "watchdog.lock")
    if not _watchdog_acquire_lock(lock):
        print("another watchdog check is live for this state home — exiting")
        return 0
    try:
        st = _watchdog_loopstate(state_dir)
        heartbeat = _watchdog_heartbeat(state_dir)
        alert = _watchdog_alert(state_dir)
        lanes_busy = _watchdog_lanes_busy(st, state_dir)
        wd = cfg.get("watchdog") if isinstance(cfg.get("watchdog"), dict) else {}
        stale_secs = wd.get("heartbeat_stale_minutes",
                            watchdog_lib.HEARTBEAT_STALE_MINUTES_DEFAULT) * 60
        hb_fresh = isinstance(heartbeat, int) and now - heartbeat <= stale_secs
        # The gh eligibility read + usage read are spent only when they can matter: a stale
        # heartbeat is already the louder signal, and a busy lane is progress by definition.
        gh_ok, eligible = (False, [])
        if hb_fresh and not lanes_busy:
            gh_ok, eligible = _watchdog_gh_view(cfg, st)
        usage_exhausted = bool(eligible) and _watchdog_usage_exhausted()

        view = {"heartbeat": heartbeat, "alert": alert, "lanes_busy": lanes_busy,
                "gh_ok": gh_ok, "eligible_nums": eligible,
                "usage_exhausted": usage_exhausted,
                "kill_switch": os.path.exists(
                    os.path.join(state_dir, watchdog_lib.KILL_SWITCH_FILENAME)),
                "debugger_live": _watchdog_debugger_live(state_dir)}
        state_path = os.path.join(state_dir, watchdog_lib.STATE_FILENAME)
        prior = watchdog_lib.coerce_state(_read_json_file(state_path, None))

        res = watchdog_lib.evaluate(now, cfg, view, prior)
        for rec in res["journal"]:
            journal.append(home, rec, now)
        for title, body in res["notify"]:
            print(f"notify: {notify.send(cfg, title, body)}")

        final = res["state"]
        if res["launch"] is not None:
            rc = _watchdog_launch(args.repo, cfg, home, state_dir, res["launch"], final)
            done = watchdog_lib.after_launch(now, cfg, final, res["launch"], rc)
            for rec in done["journal"]:
                journal.append(home, rec, now)
            for title, body in done["notify"]:
                print(f"notify: {notify.send(cfg, title, body)}")
            final = done["state"]

        loopstate.save(state_path, final)
        ep = final.get("episode")
        print("watchdog: " + ("DISABLED (state/WATCHDOG_OFF) — observed: "
                              + (", ".join(res["journal"][0]["signals"]) or "no signal")
                              if view["kill_switch"] else
                              f"episode open ({', '.join(ep['signals'])})" if ep else
                              "healthy — no signal"))
        return 0
    finally:
        _watchdog_release_lock(lock)


# ------------------------------- stubs -------------------------------

def _stub(which, wave):
    def run(args):
        print(f"`superlooper {which}` is not implemented yet — it lands in {wave}.",
              file=sys.stderr)
        return 2
    return run


def main(argv=None):
    ap = argparse.ArgumentParser(prog="superlooper", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)

    def add(name, fn, **extra):
        p = sub.add_parser(name)
        p.add_argument("--repo", default=os.getcwd(),
                       help="target repo working copy (default: cwd)")
        for flag, kw in extra.items():
            p.add_argument(flag, **kw)
        p.set_defaults(fn=fn)

    add("run", cmd_run,
        **{"--pane": dict(default=None, help="OVERRIDE the cmux pane that hosts the loop's tabs "
                                             "(default: $SL_PANE, else the pane of the cmux tab "
                                             "this command runs in — no need to set it)"),
           "--agent": dict(default=None, choices=("claude", "codex"),
                           help="coding agent for launched sessions "
                                "(default: config agent, else claude)"),
           "--ticks": dict(type=int, default=None,
                           help="stop after N ticks (testing/simulation)")})
    add("status", cmd_status)
    add("adopt", cmd_adopt)
    add("doctor", cmd_doctor,
        **{"--stack": dict(action="store_true",
                           help="check machine-level loop stack prerequisites instead of "
                                "repo-level adoption state")})
    add("nightly", cmd_nightly)
    add("morning-report", cmd_morning_report)
    add("promote-report", cmd_promote_report,
        **{"--use-latest-nightly": dict(action="store_true",
           help="reuse the latest nightly's results instead of running the suite now")})
    add("accept-failure", cmd_accept_failure,
        **{"fingerprint": dict(help="the failure fingerprint from a promotion report"),
           "--note": dict(default=None, help="why this failure is non-blocking (audit note)")})
    add("tidy", cmd_tidy,
        **{"--all": dict(action="store_true",
                         help="also close parked / needs-william / bounced session windows "
                              "(default: only merged — the truly-done sessions)"),
           "--yes": dict(action="store_true", help="skip the y/N confirmation"),
           "--dry-run": dict(action="store_true",
                             help="list the windows tidy would close, then close nothing")})
    add("request-restart", cmd_request_restart,
        **{"--check": dict(action="store_true",
                           help="report whether a live runner exists and write nothing "
                                "(a read-only preflight)"),
           "--json": dict(action="store_true",
                          help="emit a single JSON object (for a UI over the loop to parse)"),
           "--operator": dict(default=None,
                              help="operator name recorded in the request marker (audit)"),
           "--source": dict(default=None,
                            help="who asked (audit only)")})
    add("watchdog", cmd_watchdog)
    add("janitor", cmd_janitor,
        **{"--dry-run": dict(action="store_true",
                             help="list the proposals and change NOTHING anywhere"),
           "--yes": dict(action="store_true",
                         help="skip the y/N confirmation (still your word — never wire this "
                              "into a schedule)"),
           "--retry-refused": dict(action="store_true",
                                   help="re-propose actions a previous sweep recorded as "
                                        "refused/failed (state/janitor_refused.json)")})

    args = ap.parse_args(argv)
    return args.fn(args)


if __name__ == "__main__":
    sys.exit(main())
