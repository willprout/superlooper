#!/usr/bin/env python3
"""superlooper — the William-facing CLI (plan Task 10, locked decision B.6).

  run             the foreground tick loop — always VISIBLE, in a cmux tab (it self-detects that
                  tab's pane; there is no launchd runner — a paneless daemon can't work, issue #33)
  status          render lanes / gate / frozen / journal tail from state + journal (no GitHub)
  adopt           write the config template into a target repo + seed CLAUDE.md standing rules +
                  create the §C.2 label set + print branch-protection recommendations
                  (print-only in v1)
  doctor          preflight: config, required_checks (FAILS HARD when empty), gh, labels,
                  cmux, jq, launch shim, activity hooks; --stack checks machine-level blocks
  morning-report  render reports/morning-<date>.md from the journal + notify (Task 11)
  nightly         fresh worktree of origin/<dev> -> qa.nightly_cmd -> flake/persistent triage;
                  a persistent failure freezes merges + files a scoped fix issue (Task 12)
  promote-report  dev->prod EVIDENCE (suite vs known-failure ledger, merges since last promotion,
                  open issues) — NO verdict; William decides (Task 12)
  accept-failure  accept a failure by fingerprint into the ledger — one approval, ever (Task 12)
  request-restart ask the LIVE runner to restart ITSELF in its own cmux tab (issue #116): drops a
                  request marker the runner honors between ticks by re-exec'ing in place (fresh
                  engine, cleared in-memory state). Never launches/places a tab; with no live runner
                  it refuses and names the manual start. A local ops UI over the loop shells this
  tidy            close the cmux windows of FINISHED sessions (merged by default; --all extends
                  to parked/needs-william/bounced) — manual, never automatic; never touches an
                  in-flight or mid-gate lane, so it is safe to run while the runner is live
  janitor         propose GitHub-side cleanup (stale merged/superseded sl/* branches, open
                  `superseded` PRs, aged parked/needs-william issues) and execute ONLY what
                  William approves (y/N or --yes) — list/--dry-run changes nothing anywhere;
                  nothing is ever auto-closed or auto-deleted (issue #62, spec §8 V2)
  watchdog        one MECHANICAL health check (issue #66): stale heartbeat / present ALERT /
                  the no-progress shape -> notify the owner -> grace window -> launch ONE
                  unattended sl-debugger session through the launch shim. Run it on an
                  interval via templates/launchd.watchdog.plist; state/WATCHDOG_OFF disables
"""
import argparse
import glob
