def check_fail_rules():
    """First matching fail rule with times>0 fails THIS call (after the argv log, before any
    mutation) and decrements durably. Substring match on the joined argv, so one rule can target
    'issue edit' broadly or 'issue edit 5 --add-label needs-william' precisely.

    Optional `"stderr"` on a rule sets the failure's stderr text verbatim (the default echoes the
    match). This matters when the product SURFACES a refusal's stderr into a later gh call (issue
    #27: the merge-refusal memo carries gh's stderr, and a `pr merge` refusal whose message echoed
    'pr merge' would then re-match the very rule on the park's `issue comment` — a harness artifact,
    not a product bug). A realistic message like a branch-protection error avoids that echo."""
    path = os.path.join(FIX, "fail_rules.json")
    if not os.path.isfile(path):
        return
    joined = " ".join(ARGS)
    with _Lock(path):
        try:
            with open(path) as f:
                rules = json.load(f)
        except (OSError, ValueError):
            return
        if not isinstance(rules, list):
            return
        for rule in rules:
            if not isinstance(rule, dict):
                continue
            times = rule.get("times", 0)
            if isinstance(rule.get("match"), str) and rule["match"] in joined \
                    and isinstance(times, int) and times > 0:
                rule["times"] = times - 1
                fd, tmp = tempfile.mkstemp(dir=FIX, suffix=".tmp")
                with os.fdopen(fd, "w") as f:
                    json.dump(rules, f)
                os.replace(tmp, path)
                msg = rule["stderr"] if isinstance(rule.get("stderr"), str) \
                    else "forced failure (fail rule %r)" % rule["match"]
                die(msg)


def main():
    # Log EVERY invocation's FULL argv (before any sleep/fail) so tests can pin the exact gh
    # contract gh.py produces — a dropped --label/--head/--body flag or a wrong api path is then
    # caught, not masked by a permissive router.
    if FIX:
        with open(os.path.join(FIX, "calls.jsonl"), "a") as f:
            f.write(json.dumps(ARGS) + "\n")
    if os.environ.get("GH_SLEEP"):
        time.sleep(float(os.environ["GH_SLEEP"]))
    if os.environ.get("GH_FAIL"):
        die("forced failure (GH_FAIL)")
    if FIX:
        check_fail_rules()

    if STATE_PATH and os.path.isfile(STATE_PATH):
        main_stateful()
    else:
        main_fixture()


if __name__ == "__main__":
    main()
